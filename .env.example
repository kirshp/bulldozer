# BullDozer — environment / secrets template.
# Copy to .env for local use. In CI, set these as GitHub repo secrets
# (Settings → Secrets and variables → Actions). Never commit real values.

# Telegram delivery (scripts/telegram_digest.mjs, telegram-digest workflow)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Deploy token — fill the one matching your host (see README → Deploy)
# Vercel:
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
# Cloudflare Pages:
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
