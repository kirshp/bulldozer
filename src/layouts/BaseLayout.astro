---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  active?: 'home' | 'news' | 'explore' | 'sources' | 'surveys' | 'macro' | 'markets' | 'geo' | 'edu' | 'quiz' | 'glossary';
  /** Path (under base) to a page-specific OG image, e.g. `/og/whr-happiness.png`. */
  ogPath?: string;
}
const { title, description, active, ogPath } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
// Primary data sections stay as tabs; the rest lives in the burger menu
// (same pattern as the Ativa app: switcher + burger on the right edge).
const nav = [
  { id: 'news', label: 'New', href: `${base}/` },
  { id: 'explore', label: 'Top', href: `${base}/explore` },
  { id: 'macro', label: 'Macro', href: `${base}/macro` },
  { id: 'markets', label: 'Biz', href: `${base}/markets` },
  { id: 'surveys', label: 'Polls', href: `${base}/surveys` },
  { id: 'geo', label: 'Geo', href: `${base}/geo` },
];
const burger = [
  { id: 'markets', label: '💼 Business', href: `${base}/markets` },
  { id: 'edu', label: '🎓 Edu', href: `${base}/edu` },
  { id: 'quiz', label: '🎲 Country quiz', href: `${base}/quiz` },
  { id: 'glossary', label: '📖 Glossary', href: `${base}/glossary` },
  { id: 'about', label: 'ℹ️ About', href: `${base}/about` },
  { id: 'github', label: '🐙 GitHub', href: 'https://github.com/kirshp/bulldozer' },
  { id: 'contact', label: '✉️ Contact', href: 'mailto:azenha.agent@gmail.com' },
];
const fullTitle = title ? `${title} · BullDozer` : 'BullDozer — Marketing Analytics & Research';
const desc = description ?? 'Bulldoze the noise. Mine the signal. 136 public, parsed datasets — surveys, IMF & World Bank macro, markets and people. Every number sourced.';
const canonical = new URL(Astro.url.pathname, 'https://shpara.com').href;
const ogImage = `https://shpara.com${base}${ogPath ?? '/og.png'}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="manifest" href={`${base}/manifest.webmanifest`} />
    <meta name="theme-color" content="#0e0f11" />
    <script is:inline>
      // Apply the saved theme before first paint to avoid a flash (default: dark).
      try {
        if (localStorage.getItem('bd-theme') === 'light') {
          document.documentElement.setAttribute('data-theme', 'light');
          document.querySelector('meta[name="theme-color"]').setAttribute('content', '#f7f6f2');
        }
      } catch (e) { /* private mode etc. */ }
    </script>
    <link rel="apple-touch-icon" href={`${base}/icon-192.png`} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="BullDozer" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="BullDozer" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800&family=JetBrains+Mono:wght@400;600&display=swap"
      rel="stylesheet"
    />
    {import.meta.env.PROD && (
      <>
        <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-QM1PRCY7M1"></script>
        <script is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', 'G-QM1PRCY7M1');
        </script>
      </>
    )}
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a class="brand" href={`${base}/`}>
          <span class="mark">B</span>
          <span class="name">Bull<b>Dozer</b></span>
        </a>
        <nav class="nav">
          {nav.map((n) => (
            <a href={n.href} class={active === n.id ? 'active' : ''}>{n.label}</a>
          ))}
          <!-- mobile-only tabs: on desktop these live in the burger -->
          <a href={`${base}/edu`} class={`nav-extra ${active === 'edu' ? 'active' : ''}`}>Edu</a>
        </nav>
        <div class="header-tools">
          <button type="button" class="hdr-icon" id="hdr-search" aria-label="Search datasets and countries (Cmd+K)">🔍</button>
          <button type="button" class="hdr-icon" id="hdr-theme" aria-label="Toggle light/dark theme">☀️</button>
          <div class="burger-wrap">
            <button type="button" class="hdr-icon" id="hdr-burger" aria-label="More sections" aria-expanded="false" aria-controls="burger-menu">☰</button>
            <nav class="burger-menu" id="burger-menu" hidden>
              <!-- mobile-only: header icons don't fit next to the tabs -->
              <button type="button" class="bm-tool" id="bm-search">🔍 Search</button>
              <button type="button" class="bm-tool" id="bm-theme">☀️ Light theme</button>
              {burger.map((n) => (
                <a href={n.href} class={`bm-${n.id} ${active === n.id ? 'active' : ''}`}>{n.label}</a>
              ))}
            </nav>
          </div>
        </div>
      </div>
    </header>
    <div class="srch-overlay" id="srch-overlay" hidden>
      <div class="srch-box" role="dialog" aria-label="Search">
        <input type="search" id="srch-input" placeholder="Search 130+ datasets and 230 countries…" autocomplete="off" />
        <div class="srch-results" id="srch-results"></div>
      </div>
    </div>
    <script is:inline>
      (() => {
        // Theme toggle — same storage/flag the homepage toggle uses.
        const tBtn = document.getElementById('hdr-theme');
        const icon = () => { tBtn.textContent = document.documentElement.getAttribute('data-theme') === 'light' ? '🌙' : '☀️'; };
        tBtn.addEventListener('click', () => {
          const next = document.documentElement.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
          if (next === 'light') document.documentElement.setAttribute('data-theme', 'light');
          else document.documentElement.removeAttribute('data-theme');
          try { localStorage.setItem('bd-theme', next); } catch (e) { /* ignore */ }
          document.querySelector('meta[name="theme-color"]')?.setAttribute('content', next === 'light' ? '#f7f6f2' : '#0e0f11');
          icon();
        });
        icon();
        // burger copies of the header tools (shown on mobile only)
        const bmTheme = document.getElementById('bm-theme');
        const bmLabel = () => { bmTheme.textContent = document.documentElement.getAttribute('data-theme') === 'light' ? '🌙 Dark theme' : '☀️ Light theme'; };
        bmTheme.addEventListener('click', () => { tBtn.click(); bmLabel(); });
        bmLabel();

        const bBtn = document.getElementById('hdr-burger');
        const menu = document.getElementById('burger-menu');
        const close = () => { menu.hidden = true; bBtn.setAttribute('aria-expanded', 'false'); };
        bBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          menu.hidden = !menu.hidden;
          bBtn.setAttribute('aria-expanded', String(!menu.hidden));
        });
        document.addEventListener('click', (e) => { if (!menu.hidden && !menu.contains(e.target)) close(); });
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
      })();
    </script>
    <script is:inline define:vars={{ base }}>
      (() => {
        // Global search: 🔍 or Cmd/Ctrl+K → overlay over datasets + countries.
        const overlay = document.getElementById('srch-overlay');
        const input = document.getElementById('srch-input');
        const list = document.getElementById('srch-results');
        let index = null, sel = 0, rows = [];
        const open = async () => {
          overlay.hidden = false; input.value = ''; input.focus(); paint([]);
          if (!index) { try { index = await (await fetch(`${base}/data/search.json`)).json(); } catch (e) { index = []; } }
        };
        const close = () => { overlay.hidden = true; };
        const paint = (r) => {
          rows = r; sel = 0;
          list.innerHTML = r.length
            ? r.map(([ic, label, href], i) => `<a class="srch-item${i === 0 ? ' sel' : ''}" href="${base}${href}">${ic} ${label}</a>`).join('')
            : `<p class="srch-empty">${input.value ? 'Nothing found.' : 'Type to search — e.g. “inflation” or “Brazil”.'}</p>`;
        };
        const rank = (q) => {
          q = q.toLowerCase();
          return index
            .map((it) => { const l = it[1].toLowerCase(); const p = l.startsWith(q) ? 0 : l.includes(q) ? 1 : -1; return p < 0 ? null : [p, it]; })
            .filter(Boolean).sort((a, b) => a[0] - b[0] || a[1][1].localeCompare(b[1][1])).slice(0, 12).map((x) => x[1]);
        };
        input.addEventListener('input', () => paint(input.value.trim() && index ? rank(input.value.trim()) : []));
        input.addEventListener('keydown', (e) => {
          if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
            e.preventDefault();
            sel = Math.max(0, Math.min(rows.length - 1, sel + (e.key === 'ArrowDown' ? 1 : -1)));
            [...list.children].forEach((el, i) => el.classList && el.classList.toggle('sel', i === sel));
            list.children[sel]?.scrollIntoView({ block: 'nearest' });
          } else if (e.key === 'Enter' && rows[sel]) location.href = base + rows[sel][2];
        });
        document.getElementById('hdr-search').addEventListener('click', open);
        document.getElementById('bm-search').addEventListener('click', () => { document.getElementById('burger-menu').hidden = true; open(); });
        document.addEventListener('keydown', (e) => {
          if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') { e.preventDefault(); overlay.hidden ? open() : close(); }
          else if (e.key === 'Escape') close();
        });
        overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });
      })();
    </script>

    <main>
      <slot />
    </main>

    <script is:inline define:vars={{ base }}>
      if ('serviceWorker' in navigator) {
        addEventListener('load', () => navigator.serviceWorker.register(`${base}/sw.js`, { scope: `${base}/` }).catch(() => {}));
      }
    </script>

    <footer class="site-footer">
      <div class="container">
        <span>BullDozer · marketing analytics &amp; research · built on Madeira Ativa</span>
        <span>
          <a href={`${base}/about`}>About</a> ·
          <a href={`${base}/glossary`}>Glossary</a> ·
          <a href={`${base}/quiz`}>Quiz</a> ·
          <a href="mailto:azenha.agent@gmail.com">Contact</a> ·
          Public, parsed data only · sources cited per dataset
        </span>
      </div>
    </footer>
  </body>
</html>
