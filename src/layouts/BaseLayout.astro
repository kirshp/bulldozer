---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  active?: 'home' | 'explore' | 'sources' | 'surveys' | 'macro' | 'glossary';
}
const { title, description, active } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const nav = [
  { id: 'explore', label: 'Explore', href: `${base}/explore` },
  { id: 'sources', label: 'Sources', href: `${base}/sources` },
  { id: 'surveys', label: 'Surveys', href: `${base}/surveys` },
  { id: 'macro', label: 'Macro', href: `${base}/macro` },
  { id: 'glossary', label: 'Glossary', href: `${base}/glossary` },
];
const fullTitle = title ? `${title} · BullDozer` : 'BullDozer — Marketing Analytics & Research';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800&family=JetBrains+Mono:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a class="brand" href={`${base}/`}>
          <span class="mark">B</span>
          <span class="name">Bull<b>Dozer</b></span>
        </a>
        <nav class="nav">
          {nav.map((n) => (
            <a href={n.href} class={active === n.id ? 'active' : ''}>{n.label}</a>
          ))}
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <span>BullDozer · marketing analytics &amp; research · built on Madeira Ativa</span>
        <span>Public, parsed data only · sources cited per dataset</span>
      </div>
    </footer>
  </body>
</html>
