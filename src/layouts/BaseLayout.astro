---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  active?: 'home' | 'news' | 'explore' | 'sources' | 'surveys' | 'macro' | 'markets' | 'geo' | 'glossary';
}
const { title, description, active } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const nav = [
  { id: 'news', label: 'News', href: `${base}/` },
  { id: 'explore', label: 'Charts', href: `${base}/explore` },
  { id: 'macro', label: 'Macro', href: `${base}/macro` },
  { id: 'markets', label: 'Firms', href: `${base}/markets` },
  { id: 'surveys', label: 'Polls', href: `${base}/surveys` },
  { id: 'geo', label: 'Geo', href: `${base}/geo` },
];
const fullTitle = title ? `${title} · BullDozer` : 'BullDozer — Marketing Analytics & Research';
const desc = description ?? 'Bulldoze the noise. Mine the signal. 136 public, parsed datasets — surveys, IMF & World Bank macro, markets and people. Every number sourced.';
const canonical = new URL(Astro.url.pathname, 'https://shpara.com').href;
const ogImage = `https://shpara.com${base}/og.png`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="manifest" href={`${base}/manifest.webmanifest`} />
    <meta name="theme-color" content="#0e0f11" />
    <link rel="apple-touch-icon" href={`${base}/icon-192.png`} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="BullDozer" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="BullDozer" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800&family=JetBrains+Mono:wght@400;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a class="brand" href={`${base}/`}>
          <span class="mark">B</span>
          <span class="name">Bull<b>Dozer</b></span>
        </a>
        <nav class="nav">
          {nav.map((n) => (
            <a href={n.href} class={active === n.id ? 'active' : ''}>{n.label}</a>
          ))}
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <script is:inline define:vars={{ base }}>
      if ('serviceWorker' in navigator) {
        addEventListener('load', () => navigator.serviceWorker.register(`${base}/sw.js`, { scope: `${base}/` }).catch(() => {}));
      }
    </script>

    <footer class="site-footer">
      <div class="container">
        <span>BullDozer · marketing analytics &amp; research · built on Madeira Ativa</span>
        <span>
          <a href={`${base}/about`}>About</a> ·
          <a href={`${base}/glossary`}>Glossary</a> ·
          <a href="mailto:azenha.agent@gmail.com">Contact</a> ·
          Public, parsed data only · sources cited per dataset
        </span>
      </div>
    </footer>
  </body>
</html>
