---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SourceCatalog from '@components/SourceCatalog.astro';
import DatasetList from '@components/DatasetList.astro';
import CulturalMap from '@components/CulturalMap.astro';
import { datasetsByKind, getDataset } from '@data/datasets';
// RLMS covers a single country — keep it inside its study card only, out of the
// cross-country topic blocks and the filter chips.
const items = datasetsByKind('survey').filter((d) => !d.slug.startsWith('rlms-'));
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Inglehart-Welzel cultural map — the headline 2-D values picture.
const sec = getDataset('wvs-secular');
const emo = getDataset('wvs-emancipative');
const secByIso = sec ? new Map(sec.data.map((o) => [o.iso, o])) : new Map();
const HIGHLIGHT = new Set(['Germany', 'United States', 'Japan', 'China', 'Russia', 'Sweden', 'Egypt', 'Brazil', 'Nigeria', 'India', 'Iran', 'South Korea']);
const points = (emo?.data || [])
  .filter((o) => o.iso && secByIso.has(o.iso))
  .map((o) => ({ x: o.value, y: secByIso.get(o.iso)!.value, label: o.entity, group: o.group, highlight: HIGHLIGHT.has(o.entity) }));
---
<BaseLayout title="Polls" active="surveys">
  <section class="section">
    <div class="container">
      <span class="kicker">Polls</span>
      <h2>Opinion &amp; perception studies</h2>
      <p class="page-tagline">The right dose of insight.</p>
      <p class="sub">What people say — {items.length} survey datasets on wellbeing, attitudes and risk perception. Search or browse by topic.</p>
      {points.length > 0 && (
        <div class="study-map">
          <h3 style="margin:6px 0 2px">The cultural map of the world</h3>
          <p class="sub">Every country on two value dimensions — survival ↔ self-expression and traditional ↔ secular (World Values Survey, Wave 7), coloured by cultural zone. Hover a country for its scores.</p>
          <CulturalMap />
          <p style="margin:8px 0 28px"><a class="ghost-btn" style="margin:0; display:inline-block; text-decoration:none" href={`${base}/stories/cultural-map`}>Open the full cultural map →</a></p>
        </div>
      )}
    </div>
  </section>

  <section class="section" style="padding-top:0" id="studies">
    <div class="container">
      <h2>Studies — one card per survey</h2>
      <p class="sub">Everything we parsed from each study in one place: all its indicators, plus the full results dashboard where we built one.</p>
      <SourceCatalog kind="survey" mode="live" />
    </div>
  </section>

  <section class="section" style="padding-top:0" id="indicators">
    <div class="container">
      <h2>All survey indicators</h2>
      <p class="sub">The same data sliced by topic — search, or filter by study.</p>
      <DatasetList items={items} />
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      <h2>More programmes in the catalogue</h2>
      <p class="sub">Gathered and documented — microdata available from the official source, not yet aggregated into BullDozer.</p>
      <SourceCatalog kind="survey" mode="catalog" />
    </div>
  </section>
</BaseLayout>
