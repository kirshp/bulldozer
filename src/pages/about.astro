---
import BaseLayout from '../layouts/BaseLayout.astro';
import { datasets } from '@data/datasets';
import { sources } from '@data/sources';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const live = sources.filter((s) => s.status === 'live').length;
---
<BaseLayout title="About" description="How BullDozer is built: only public, parsed data, with cited provenance and transparent methodology.">
  <section class="section">
    <div class="container" style="max-width:760px">
      <span class="kicker">About</span>
      <h2>What BullDozer is</h2>
      <p class="sub">
        BullDozer turns <b>public, parsed</b> survey and macro data into clean dashboards, maps and visual stories —
        built on the Madeira Ativa analytics engine. {datasets.length} datasets from {live} live sources, every number cited.
      </p>

      <div class="gloss-term"><h3>Only public, redistributable data</h3>
        <p>Every dataset comes from an open, redistributable source (IMF, World Bank, OWID, V-Dem, WVS, Gallup-based polls and more). Each carries its source, licence, unit and parse date. We do not use paywalled or proprietary feeds.</p></div>

      <div class="gloss-term"><h3>One concept, one source</h3>
        <p>Where several sources publish the same metric, we pick a single primary to avoid duplicates — economics from the IMF, development from Gapminder/OWID, governance from V-Dem/QoG, culture from WVS/Hofstede.</p></div>

      <div class="gloss-term"><h3>How change is measured</h3>
        <p>Rates and percentages are compared in <b>percentage points</b>; counts and volumes in <b>percent</b>. Countries are classified improving / declining / stable within a ±0.5 band so noise isn’t read as a trend. See the <a href={`${base}/glossary`}>glossary</a>.</p></div>

      <div class="gloss-term"><h3>Microdata, aggregated transparently</h3>
        <p>Survey microdata (World Values Survey, World Risk Poll, RLMS…) is aggregated to country level with survey weights. Single-wave surveys show no period-over-period change.</p></div>

      <div class="gloss-term"><h3>Freshness</h3>
        <p>Macro and survey releases follow a calendar (IMF WEO twice a year, World Happiness in March, V-Dem in March…). See the <a href={`${base}/`}>release calendar</a> on the homepage. Every dataset is downloadable as CSV.</p></div>

      <p class="sub" style="margin-top:24px">
        Browse the <a href={`${base}/macro`}>data</a>, open the <a href={`${base}/explore`}>explorer</a>, or read the <a href={`${base}/`}>stories</a>.
      </p>
    </div>
  </section>
</BaseLayout>
