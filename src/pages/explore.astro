---
import BaseLayout from '../layouts/BaseLayout.astro';
import DataPanel from '@components/DataPanel.astro';
import CountryPanel from '@components/CountryPanel.astro';
import CompareCountries from '@components/CompareCountries.astro';
import BivariateExplore from '@components/BivariateExplore.astro';
import BubbleChart from '@components/BubbleChart.astro';
import CorrelationMatrix from '@components/CorrelationMatrix.astro';
import SingleIndicatorViz from '@components/SingleIndicatorViz.astro';
import CountryHeatmap from '@components/CountryHeatmap.astro';
import ConnectedScatter from '@components/ConnectedScatter.astro';
import { datasets } from '@data/datasets';

const indicators = datasets.map((d) => ({
  slug: d.slug, title: d.title, kind: d.kind, unit: d.unit, valueLabel: d.valueLabel, topic: d.topic,
  changeMode: d.changeMode, periods: [...new Set(d.data.map((o) => o.period))].sort(),
}));
---
<BaseLayout title="Explore" active="explore" description="Interactive explorer: pick an indicator, period and countries; view as bars, table or world map.">
  <section class="section" id="explorer">
    <div class="container">
      <nav class="explore-nav">
        <a class="ghost-btn" href="#explorer">🔍 Explorer</a>
        <a class="ghost-btn" href="#bivariate">🗺️ Bivariate map</a>
        <a class="ghost-btn" href="#bubble">🫧 Bubble chart</a>
        <a class="ghost-btn" href="#correlation">🔥 Correlations</a>
        <a class="ghost-btn" href="#distribution">📊 Distribution</a>
        <a class="ghost-btn" href="#heatmap">🌡️ Heatmap</a>
        <a class="ghost-btn" href="#path">🛰️ Trajectories</a>
        <a class="ghost-btn" href="#country">🌍 Country profile</a>
        <a class="ghost-btn" href="#compare">⚖️ Compare countries</a>
      </nav>
      <span class="kicker">Interactive explorer</span>
      <h2>Explore the data</h2>
      <p class="sub">Pick an indicator, period and countries. Switch between bars, table and world map.</p>
      <DataPanel indicators={indicators} />
    </div>
  </section>

  <section class="section" style="padding-top:0" id="bivariate">
    <div class="container">
      <span class="kicker">Bivariate map</span>
      <h2>Two indicators, one map</h2>
      <p class="sub">See how two measures combine across the world — colour mixes amber (X) and blue (Y).</p>
      <BivariateExplore indicators={indicators} />
    </div>
  </section>

  <section class="section" style="padding-top:0" id="bubble">
    <div class="container">
      <span class="kicker">Bubble chart</span>
      <h2>Three indicators, moving through time</h2>
      <p class="sub">Gapminder-style — X, Y and bubble size are three different datasets merged on country & year; press play to watch the world move.</p>
      <BubbleChart indicators={indicators} />
    </div>
  </section>

  <section class="section" style="padding-top:0" id="correlation">
    <div class="container">
      <span class="kicker">Correlations</span>
      <h2>What moves together</h2>
      <p class="sub">Pearson correlation between key indicators across countries — green = move together, red = move apart.</p>
      <CorrelationMatrix />
    </div>
  </section>

  <section class="section" style="padding-top:0" id="distribution">
    <div class="container">
      <span class="kicker">Distribution &amp; movement</span>
      <h2>The whole field at once</h2>
      <p class="sub">One indicator, three ways — every country as a dot (beeswarm), the change between years (slope), or an animated ranking (bar race).</p>
      <SingleIndicatorViz indicators={indicators} />
    </div>
  </section>

  <section class="section" style="padding-top:0" id="heatmap">
    <div class="container">
      <span class="kicker">Heatmap</span>
      <h2>Countries × indicators</h2>
      <p class="sub">A topic at a glance — every country’s strengths and weaknesses, cells coloured by global percentile.</p>
      <CountryHeatmap />
    </div>
  </section>

  <section class="section" style="padding-top:0" id="path">
    <div class="container">
      <span class="kicker">Trajectories</span>
      <h2>Where countries are heading</h2>
      <p class="sub">A connected scatter — each country’s path through two indicators over time. Are they moving up-and-right, or sliding back?</p>
      <ConnectedScatter indicators={indicators} />
    </div>
  </section>

  <section class="section" style="padding-top:0" id="country">
    <div class="container">
      <span class="kicker">Country profile</span>
      <h2>One country, every indicator</h2>
      <p class="sub">Pick a country to see all its statistics and where it ranks — highlighted on the map.</p>
      <CountryPanel />
    </div>
  </section>

  <section class="section" style="padding-top:0" id="compare">
    <div class="container">
      <span class="kicker">Compare</span>
      <h2>Country vs country</h2>
      <p class="sub">Put a few countries side by side across every indicator. Highest in each row is highlighted.</p>
      <CompareCountries />
    </div>
  </section>
</BaseLayout>
