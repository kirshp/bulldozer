---
import BaseLayout from '../layouts/BaseLayout.astro';
import QuizGame from '../components/QuizGame.astro';
import EuropeMap from '@components/EuropeMap.astro';
import { datasets, datasetsByKind, getDataset } from '@data/datasets';
import { upcoming } from '@data/releases';
import { stories as storyList } from '@data/stories';
import cities from '@data/cities.json';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Mini preview for the cities card — top-5 most liveable European cities.
const cityTop = cities.metrics[0].data.slice(0, 5);
const cityMax = Math.max(1, ...cityTop.map((d) => d.value));

// Featured story — the happiest countries, previewed with the Europe map.
const happy = getDataset('whr-happiness');
const happyLatest = happy ? [...new Set(happy.data.map((o) => o.period))].sort().at(-1) : null;
const month = new Date().getMonth() + 1;
const calendar = upcoming(month).slice(0, 6);

const stories = storyList.map((s) => ({ ...s, href: `${base}/stories/${s.slug}` }));
const [feature, ...rest] = stories;

const picks = ['imf-gdp-growth', 'v-dem-v2x-libdem', 'gapminder-life-expectancy', 'imf-inflation', 'qog-ti-cpi', 'gapminder-internet']
  .map((s) => getDataset(s)).filter(Boolean) as NonNullable<ReturnType<typeof getDataset>>[];

const browse = [
  { title: 'Charts', href: `${base}/explore`, desc: 'Pick any indicator, period and country — bars, table or world map.' },
  { title: 'Macro', href: `${base}/macro`, desc: `${datasetsByKind('macro').length} objective indicators — economy, demographics, health, governance, environment, risk.` },
  { title: 'Polls', href: `${base}/surveys`, desc: `${datasetsByKind('survey').length} opinion & perception studies — happiness, attitudes, risk perception.` },
  { title: 'Glossary', href: `${base}/glossary`, desc: 'Plain-language explanations of every metric and method.' },
];
---
<BaseLayout active="news">
  <section class="hero">
    <div class="container">
      <div class="hero-tools">
        <div class="pwa-hint" id="pwa-hint" hidden>
          <button type="button" class="pwa-chip" id="pwa-chip">📱 Get the app</button>
          <div class="pwa-pop" id="pwa-pop" hidden>
            <p><b>BullDozer Stats on your phone.</b> Native apps for Android &amp; iOS, or install this site as a web app.</p>
            <div class="app-links">
              <a class="app-link" href={`${base}/downloads/bulldozer-stats.apk`} download>
                <svg class="app-ico" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M7.2 8.4h9.6v7.4c0 .7-.6 1.3-1.3 1.3h-.8v2.2c0 .6-.5 1.1-1.1 1.1s-1.1-.5-1.1-1.1v-2.2h-1v2.2c0 .6-.5 1.1-1.1 1.1s-1.1-.5-1.1-1.1v-2.2h-.8c-.7 0-1.3-.6-1.3-1.3V8.4Zm-2.1.2c.6 0 1.1.5 1.1 1.1v4.8c0 .6-.5 1.1-1.1 1.1S4 15.1 4 14.5V9.7c0-.6.5-1.1 1.1-1.1Zm13.8 0c.6 0 1.1.5 1.1 1.1v4.8c0 .6-.5 1.1-1.1 1.1s-1.1-.5-1.1-1.1V9.7c0-.6.5-1.1 1.1-1.1ZM8.1 7.3c.2-1.2.9-2.2 1.8-2.8L9 2.9c-.1-.2 0-.4.2-.5s.4 0 .5.2l.9 1.6c.4-.1.9-.2 1.4-.2s1 .1 1.4.2l.9-1.6c.1-.2.3-.3.5-.2s.3.3.2.5l-.9 1.6c.9.6 1.6 1.6 1.8 2.8H8.1Zm2.1-1.5c-.3 0-.5.2-.5.5s.2.5.5.5.5-.2.5-.5-.2-.5-.5-.5Zm3.6 0c-.3 0-.5.2-.5.5s.2.5.5.5.5-.2.5-.5-.2-.5-.5-.5Z"/></svg>
                <span>Android<small>APK · 16 MB</small></span>
              </a>
              <a class="app-link" href="mailto:aurapark888@gmail.com?subject=BullDozer%20Stats%20iOS%20request">
                <svg class="app-ico" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M16.4 12.8c0-2.1 1.7-3.1 1.8-3.2-1-1.4-2.5-1.6-3-1.6-1.3-.1-2.5.7-3.1.7-.7 0-1.7-.7-2.8-.7-1.4 0-2.7.8-3.4 2.1-1.5 2.6-.4 6.4 1.1 8.5.7 1 1.5 2.2 2.7 2.1 1.1 0 1.5-.7 2.8-.7s1.7.7 2.8.7c1.2 0 1.9-1 2.6-2.1.8-1.2 1.1-2.3 1.2-2.4 0 0-2.7-1-2.7-3.4ZM14.3 6.6c.6-.7 1-1.7.9-2.7-.9 0-1.9.6-2.5 1.3-.6.7-1 1.6-.9 2.6 1 .1 2-.5 2.5-1.2Z"/></svg>
                <span>iOS<small>request</small></span>
              </a>
              <button type="button" class="app-link" id="pwa-webapp">
                <svg class="app-ico" viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M17 1.01 7 1c-1.1 0-2 .9-2 2v18c0 1.1.9 2 2 2h10c1.1 0 2-.9 2-2V3c0-1.1-.9-1.99-2-1.99ZM17 19H7V5h10v14Zm-4-7v4h-2v-4H8l4-4 4 4h-3Z"/></svg>
                <span>Web app<small>PWA</small></span>
              </button>
            </div>
            <p class="pwa-ios" hidden>On iPhone (Safari): tap <b>Share</b> ⬆️ → <b>Add to Home Screen</b>.</p>
            <p class="pwa-other">Android APK: allow <b>install from unknown sources</b> when your phone asks.</p>
          </div>
        </div>
        <button type="button" class="pwa-chip" id="theme-toggle">☀️ Light theme</button>
      </div>
      <span class="kicker">Marketing Analytics &amp; Research</span>
      <h1>Bulldoze the noise. <span class="hl">Mine the signal.</span></h1>
      <p>Visual data stories and {datasets.length} public, parsed datasets — surveys, IMF & World Bank macro, democracy and wellbeing — every number sourced, every metric explained.</p>
    </div>
  </section>

  <script>
    (function () {
      const hint = document.getElementById('pwa-hint');
      if (!hint) return;
      const chip = document.getElementById('pwa-chip');
      const pop = document.getElementById('pwa-pop');
      const webappBtn = document.getElementById('pwa-webapp');
      const isIOS = /iphone|ipad|ipod/i.test(navigator.userAgent);
      hint.querySelector('.pwa-ios').hidden = !isIOS;
      hint.querySelector('.pwa-other').hidden = isIOS;
      hint.hidden = false;                          // native downloads work on any device
      let deferred = null;
      window.addEventListener('beforeinstallprompt', (e) => { e.preventDefault(); deferred = e; });
      chip.addEventListener('click', () => { pop.hidden = !pop.hidden; });
      webappBtn.addEventListener('click', async () => {
        if (deferred) { deferred.prompt(); await deferred.userChoice; deferred = null; pop.hidden = true; }
        // no native prompt (iOS / already installed): the manual hint below stays visible
      });
      document.addEventListener('click', (e) => { if (!hint.contains(e.target)) pop.hidden = true; });
      window.addEventListener('appinstalled', () => { pop.hidden = true; });
    })();

    (function () {
      const btn = document.getElementById('theme-toggle');
      if (!btn) return;
      const isLight = () => document.documentElement.getAttribute('data-theme') === 'light';
      const label = () => { btn.textContent = isLight() ? '🌙 Dark theme' : '☀️ Light theme'; };
      btn.addEventListener('click', () => {
        const next = isLight() ? 'dark' : 'light';
        if (next === 'light') document.documentElement.setAttribute('data-theme', 'light');
        else document.documentElement.removeAttribute('data-theme');
        try { localStorage.setItem('bd-theme', next); } catch (e) { /* ignore */ }
        document.querySelector('meta[name="theme-color"]')?.setAttribute('content', next === 'light' ? '#f7f6f2' : '#0e0f11');
        label();
      });
      label();
    })();
  </script>

  <section class="section" id="stories">
    <div class="container">
      <nav class="explore-nav">
        <a class="ghost-btn" href="#stories">📰 Stories</a>
        <a class="ghost-btn" href="#dashboards">📊 Dashboards</a>
        <a class="ghost-btn" href="#releases">🗓️ Data releases</a>
        <a class="ghost-btn" href="#browse">🧭 Browse</a>
      </nav>
      <span class="kicker">News &amp; data stories</span>
      <h2>What the data is saying</h2>
      <p class="sub">Visual stories built on public data.</p>

      <div class="card news-card news-feature" style="margin-top:8px">
        <a class="news-feature-head" href={feature.href}>
          <span class="tag">{feature.tag}</span>
          <h3>{feature.title}</h3>
          <p class="meta">{feature.dek}</p>
        </a>
        <p class="meta" style="margin:6px 0 2px">Europe at a glance — countries shaded by happiness, each dot a city sized by its rating. Hover for detail; click a country to focus it.</p>
        <EuropeMap />
        <a class="meta feature-more" href={feature.href} style="color:var(--accent); display:inline-block; margin-top:14px">Read the story · happiest countries {happyLatest} →</a>
      </div>

      <div class="quiz-box">
        <div class="quiz-row">
          <span class="quiz-blurb"><span class="q-emo">🎯</span> <b>Country Quiz</b> — one mystery country, five real statistics. Most people lose to a chimp. Will you?</span>
          <span class="quiz-btns">
            <a class="quiz-play" id="quiz-play" href={`${base}/quiz`}>New game 🎲</a>
            <a class="ghost-btn" href={`${base}/explore`} style="margin:0">Try other charts →</a>
          </span>
        </div>
        <QuizGame autostart />
      </div>
      <script>
        // The game auto-starts below; this button restarts it. The href to /quiz
        // stays as the no-JS fallback.
        document.getElementById('quiz-play')?.addEventListener('click', (e) => {
          e.preventDefault();
          document.getElementById('q-start-btn')!.click();
          document.getElementById('quiz-game-root')!.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        });
      </script>

      <a class="card link news-card" href={`${base}/cities`} style="display:block; margin-top:16px">
        <span class="tag">Cities · Europe</span>
        <h3>Best cities to live in Europe</h3>
        <p class="meta">A livability ranking of {cities.metrics[0].data.length} cities from the EU’s open quality-of-life survey.</p>
        <div class="bars feature-bars" style="margin:12px 0 4px">
          {cityTop.map((d) => (
            <div class="bar-row">
              <span>{d.city} <em style="color:var(--text-dim)">{d.cc}</em></span>
              <span class="bar-track"><span class="bar-fill" style={`width:${(d.value / cityMax) * 100}%`}></span></span>
              <span class="bar-val">{d.value}</span>
            </div>
          ))}
        </div>
      </a>

      <div class="grid cols-2" style="margin-top:16px">
        {rest.map((s) => (
          <a class="card link news-card" href={s.href}>
            <span class="tag">{s.tag}</span>
            <h3>{s.title}</h3>
            <p class="meta">{s.dek}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section" style="padding-top:0" id="dashboards">
    <div class="container">
      <h2>Featured dashboards</h2>
      <p class="sub">Jump straight into the numbers.</p>
      <div class="grid cols-3">
        {picks.map((d) => (
          <a class="card link" href={`${base}/dataset/${d.slug}`}>
            <h3 style="font-size:16px">{d.title}</h3>
            <p class="meta">{d.summary}</p>
            <span class="pill">{d.source}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section" style="padding-top:0" id="releases">
    <div class="container">
      <h2>Data release calendar</h2>
      <p class="sub">When the next big numbers drop — sorted by what’s coming up.</p>
      <div class="releases">
        {calendar.map((r) => (
          <a class="rel-row" href={r.url} target="_blank" rel="noopener">
            <span class={`rel-when ${r.kind}`}>{r.window}</span>
            <span class="rel-body">
              <b>{r.name} ↗</b>
              <span class="meta">{r.description}</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section" style="padding-top:0" id="browse">
    <div class="container">
      <h2>Browse</h2>
      <p class="sub">All {datasets.length} datasets, every source, fully interactive.</p>
      <div class="grid cols-2">
        {browse.map((b) => (
          <a class="card link" href={b.href}>
            <h3>{b.title}</h3>
            <p class="meta">{b.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
