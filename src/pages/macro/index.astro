---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SourceCatalog from '@components/SourceCatalog.astro';
import DatasetList from '@components/DatasetList.astro';
import EuropeMap from '@components/EuropeMap.astro';
import { datasetsByKind } from '@data/datasets';
const items = datasetsByKind('macro');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="Macro" active="macro">
  <section class="section">
    <div class="container">
      <span class="kicker">Macro</span>
      <h2>Macro, Country &amp; City statistics</h2>
      <p class="page-tagline">Bullish on the numbers.</p>
      <p class="sub">Objective indicators across {datasetsByKind('macro').length} datasets — economy, demographics, health, education, environment, governance and risk. Search or browse by topic.</p>
      <h3 style="margin:6px 0 2px">Happiness across Europe</h3>
      <p class="sub">Countries shaded by the World Happiness Report score; each dot is a city sized by its rating. Hover for detail, click a country to focus it. <a href={`${base}/dataset/gapminder-internet`}>The internet-adoption chart</a> that used to live here is one click away.</p>
      <EuropeMap />
      <DatasetList items={items} />
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      <h2>Sources we gathered</h2>
      <p class="sub">Every statistical source — with an official link and a short description.</p>
      <SourceCatalog kind="macro" />
    </div>
  </section>
</BaseLayout>
