---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Provenance from '@components/Provenance.astro';
import KpiRow from '@components/KpiRow.astro';
import DataPanel from '@components/DataPanel.astro';
import MoversTable from '@components/MoversTable.astro';
import GroupChart from '@components/GroupChart.astro';
import TrendChart from '@components/TrendChart.astro';
import BivariateMap from '@components/BivariateMap.astro';
import { datasets, getDataset } from '@data/datasets';

// Curated bivariate pairings — a "good" second dimension per indicator.
const PAIRINGS: Record<string, { y: string; title: string }> = {
  'whr-happiness': { y: 'imf-gdp-per-capita-ppp', title: 'Happiness × wealth — colour shows both at once' },
  'gapminder-life-expectancy': { y: 'imf-gdp-per-capita-ppp', title: 'Longevity × wealth' },
  'gapminder-internet': { y: 'imf-gdp-per-capita-ppp', title: 'Internet access × wealth' },
  'v-dem-v2x-libdem': { y: 'qog-ti-cpi', title: 'Liberal democracy × clean government' },
  'qog-ti-cpi': { y: 'v-dem-v2x-libdem', title: 'Clean government × liberal democracy' },
  'imf-gdp-growth': { y: 'imf-inflation', title: 'Growth × inflation' },
  'imf-inflation': { y: 'imf-gdp-growth', title: 'Inflation × growth' },
};
import { groupRollups, isSinglePeriod, isAdditive } from '@lib/analytics';
import { formatChange, pctClass, formatNum } from '@lib/format';
import { TOPICS } from '@lib/topics';

export function getStaticPaths() {
  return datasets.map((d) => ({ params: { slug: d.slug } }));
}

const { slug } = Astro.params;
const ds = getDataset(slug!)!;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
// Detailed pre-built frequency / by-country dashboards (static HTML in /public).
const DASH: Record<string, string> = {
  'wvs-': 'wvs', 'afro-': 'afrobarometer', 'wgm-': 'wellcome', 'wrp-': 'wrp',
  'sdr2-': 'sdr2', 'v-dem-': 'vdem', 'whr-': 'whr', 'gapminder-': 'gapminder',
};
const dashFile = Object.entries(DASH).find(([p]) => ds.slug.startsWith(p))?.[1];
const additive = isAdditive(ds.unit);
const groups = groupRollups(ds.data, ds.changeMode, additive);
const single = isSinglePeriod(ds.data);
const periodCount = new Set(ds.data.map((o) => o.period)).size;
const pairing = PAIRINGS[ds.slug];
const related = datasets.filter((d) => d.topic === ds.topic && d.slug !== ds.slug).slice(0, 6);
const pctUnit = ds.unit === '%' ? '%' : '';
const panelIndicator = [{
  slug: ds.slug, title: ds.title, kind: ds.kind, unit: ds.unit, valueLabel: ds.valueLabel,
  changeMode: ds.changeMode, periods: [...new Set(ds.data.map((o) => o.period))].sort(),
}];
const backHref = ds.kind === 'survey' ? `${base}/surveys` : `${base}/macro`;
const active = ds.kind === 'survey' ? 'surveys' : 'macro';
---
<BaseLayout title={ds.title} description={ds.summary} active={active}>
  <section class="section">
    <div class="container">
      <a class="back-link" href={backHref}>← {ds.kind === 'survey' ? 'Study' : 'Macro'}</a>
      <h2><span class="ind-ic" aria-hidden="true">{TOPICS[ds.topic]?.icon}</span>{ds.title}</h2>
      <p class="sub">{ds.summary}</p>
      <Provenance meta={ds} />
      {(ds.vintage || ds.method) && (
        <p class="method-note">
          {ds.vintage && <span><b>Period:</b> {ds.vintage}. </span>}
          {ds.method && <span><b>Method:</b> {ds.method}</span>}
        </p>
      )}
      <p style="margin-top:12px; display:flex; gap:10px; flex-wrap:wrap">
        <a class="ghost-btn" style="margin:0; display:inline-block; text-decoration:none" href={`${base}/data/${ds.slug}.csv`} download>↓ Download CSV</a>
        {dashFile && (
          <a class="ghost-btn" style="margin:0; display:inline-block; text-decoration:none" href={`${base}/dashboards/${dashFile}.html`} target="_blank" rel="noopener">📊 Detailed results dashboard ↗</a>
        )}
      </p>
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      <KpiRow data={ds.data} unit={pctUnit} mode={ds.changeMode} />
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      <h2>{ds.valueLabel}</h2>
      <p class="sub">Interactive — choose a period, search a country, switch between bars, table and map.</p>
      <DataPanel indicators={panelIndicator} pinnedSlug={ds.slug} />
    </div>
  </section>

  {periodCount > 2 && (
    <section class="section" style="padding-top:0">
      <div class="container">
        <h2>Trend over time</h2>
        <p class="sub">Group average by period, {[...new Set(ds.data.map((o) => o.period))].sort()[0]}–{[...new Set(ds.data.map((o) => o.period))].sort().at(-1)}.</p>
        <TrendChart data={ds.data} unit={pctUnit} />
      </div>
    </section>
  )}

  {pairing && (
    <section class="section" style="padding-top:0">
      <div class="container">
        <h2>Two dimensions at once</h2>
        <BivariateMap xSlug={ds.slug} ySlug={pairing.y} title={pairing.title} />
      </div>
    </section>
  )}

  {!single && (
    <section class="section" style="padding-top:0">
      <div class="container">
        <h2>Movers</h2>
        <p class="sub">Biggest period-over-period changes.</p>
        <MoversTable data={ds.data} n={5} unit={pctUnit} mode={ds.changeMode} />
      </div>
    </section>
  )}

  {groups.length > 0 && !single && (
    <section class="section" style="padding-top:0" id="groups">
      <div class="container">
        <h2>By group</h2>
        <p class="sub">Change by group, latest period.</p>
        <GroupChart data={ds.data} mode={ds.changeMode} additive={additive} />
        <div style="height:24px"></div>
        <table class="data">
          <thead><tr><th>Group</th><th class="num">Members</th><th class="num">{additive ? 'Total' : 'Avg'}</th><th class="num">Change</th></tr></thead>
          <tbody>
            {groups.map((g) => (
              <tr>
                <td>{g.group}</td>
                <td class="num">{g.members}</td>
                <td class="num">{formatNum(g.value)}{pctUnit}</td>
                <td class={`num ${pctClass(g.pct)}`}>{formatChange(g.pct, ds.changeMode)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )}

  {related.length > 0 && (
    <section class="section" style="padding-top:0">
      <div class="container">
        <h2>Related indicators</h2>
        <p class="sub">More in {ds.topic}.</p>
        <div class="grid cols-3">
          {related.map((d) => (
            <a class="card link" href={`${base}/dataset/${d.slug}`}>
              <h3 style="font-size:15px"><span class="ind-ic" aria-hidden="true">{TOPICS[d.topic]?.icon}</span>{d.title}</h3>
              <p class="meta">{d.source}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
