---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Provenance from '@components/Provenance.astro';
import KpiRow from '@components/KpiRow.astro';
import BarList from '@components/BarList.astro';
import MoversTable from '@components/MoversTable.astro';
import { datasets, getDataset } from '@data/datasets';
import { groupRollups } from '@lib/analytics';
import { formatPct, pctClass } from '@lib/format';

export function getStaticPaths() {
  return datasets.map((d) => ({ params: { slug: d.slug } }));
}

const { slug } = Astro.params;
const ds = getDataset(slug!)!;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const groups = groupRollups(ds.data);
const backHref = ds.kind === 'survey' ? `${base}/surveys` : `${base}/macro`;
const active = ds.kind === 'survey' ? 'surveys' : 'macro';
---
<BaseLayout title={ds.title} description={ds.summary} active={active}>
  <section class="section">
    <div class="container">
      <p class="meta"><a href={backHref}>← {ds.kind === 'survey' ? 'Surveys' : 'Macro'}</a></p>
      <h2>{ds.title}</h2>
      <p class="sub">{ds.summary}</p>
      <Provenance meta={ds} />
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      <KpiRow data={ds.data} unit={ds.unit === '%' ? '%' : ''} />
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      <h2>{ds.valueLabel} — leaders</h2>
      <p class="sub">Latest period, top entities.</p>
      <BarList data={ds.data} n={10} unit={ds.unit === '%' ? '%' : ''} />
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      <h2>Movers</h2>
      <p class="sub">Biggest period-over-period changes.</p>
      <MoversTable data={ds.data} n={5} unit={ds.unit === '%' ? '%' : ''} />
    </div>
  </section>

  {groups.length > 0 && (
    <section class="section" style="padding-top:0">
      <div class="container">
        <h2>By group</h2>
        <p class="sub">Rollup across {groups.length} groups.</p>
        <table class="data">
          <thead><tr><th>Group</th><th class="num">Members</th><th class="num">Total</th><th class="num">Change</th></tr></thead>
          <tbody>
            {groups.map((g) => (
              <tr>
                <td>{g.group}</td>
                <td class="num">{g.members}</td>
                <td class="num">{g.value}{ds.unit === '%' ? '' : ''}</td>
                <td class={`num ${pctClass(g.pct)}`}>{formatPct(g.pct)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )}
</BaseLayout>
