---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Provenance from '@components/Provenance.astro';
import KpiRow from '@components/KpiRow.astro';
import BarList from '@components/BarList.astro';
import MoversTable from '@components/MoversTable.astro';
import GroupChart from '@components/GroupChart.astro';
import { datasets, getDataset } from '@data/datasets';
import { groupRollups } from '@lib/analytics';
import { formatChange, pctClass } from '@lib/format';

export function getStaticPaths() {
  return datasets.map((d) => ({ params: { slug: d.slug } }));
}

const { slug } = Astro.params;
const ds = getDataset(slug!)!;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const groups = groupRollups(ds.data, ds.changeMode);
const pctUnit = ds.unit === '%' ? '%' : '';
const backHref = ds.kind === 'survey' ? `${base}/surveys` : `${base}/macro`;
const active = ds.kind === 'survey' ? 'surveys' : 'macro';
---
<BaseLayout title={ds.title} description={ds.summary} active={active}>
  <section class="section">
    <div class="container">
      <p class="meta"><a href={backHref}>← {ds.kind === 'survey' ? 'Surveys' : 'Macro'}</a></p>
      <h2>{ds.title}</h2>
      <p class="sub">{ds.summary}</p>
      <Provenance meta={ds} />
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      <KpiRow data={ds.data} unit={pctUnit} mode={ds.changeMode} />
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      <h2>{ds.valueLabel} — leaders</h2>
      <p class="sub">Latest period, top entities.</p>
      <BarList data={ds.data} n={10} unit={pctUnit} />
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      <h2>Movers</h2>
      <p class="sub">Biggest period-over-period changes.</p>
      <MoversTable data={ds.data} n={5} unit={pctUnit} mode={ds.changeMode} />
    </div>
  </section>

  {groups.length > 0 && (
    <section class="section" style="padding-top:0" id="groups">
      <div class="container">
        <h2>By group</h2>
        <p class="sub">Change by group, latest period.</p>
        <GroupChart data={ds.data} mode={ds.changeMode} />
        <div style="height:24px"></div>
        <table class="data">
          <thead><tr><th>Group</th><th class="num">Members</th><th class="num">{ds.changeMode === 'pp' ? 'Avg' : 'Total'}</th><th class="num">Change</th></tr></thead>
          <tbody>
            {groups.map((g) => (
              <tr>
                <td>{g.group}</td>
                <td class="num">{g.members}</td>
                <td class="num">{g.value}{pctUnit}</td>
                <td class={`num ${pctClass(g.pct)}`}>{formatChange(g.pct, ds.changeMode)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )}
</BaseLayout>
