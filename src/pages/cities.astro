---
import BaseLayout from '../layouts/BaseLayout.astro';
import EuropeMap from '@components/EuropeMap.astro';
import cities from '@data/cities.json';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const desc = `The best cities to live in across Europe — a livability ranking over ${cities.metrics[0].data.length} cities from the open EU quality-of-life survey, ${cities.year}.`;
---
<BaseLayout title="Happiest European cities" description={desc} active="geo">
  <section class="section">
    <div class="container">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href={`${base}/geo`}>Geo</a><span aria-hidden="true">›</span><span class="crumb-here">Cities</span>
      </nav>
      <span class="kicker">Geo · Cities</span>
      <h2>Best cities to live in Europe</h2>
      <p class="sub">
        A livability ranking of {cities.metrics[0].data.length} cities from the EU’s open perception survey ({cities.year}) — an
        overall composite plus the six dimensions behind it. City-level and Europe-only: the one
        openly-licensed city ranking (Mercer, EIU and the Economist’s indices are proprietary).
      </p>

      <h3 style="margin:22px 0 2px">Happiness across Europe — countries and their cities</h3>
      <p class="sub" style="margin:0 0 6px">
        Countries shaded by the World Happiness Report life-evaluation score; each dot is a city, sized by its
        rating on the metric you pick and coloured by whether it ranks <b>above</b> or <b>below</b> its own country.
        Two scales (a 0–10 ladder for countries, “% satisfied” for cities), so they stay on separate encodings —
        but city satisfaction tracks national happiness closely (r ≈ 0.69).
      </p>
      <EuropeMap />

      <h3 style="margin:30px 0 2px">City rankings</h3>
      <div class="ci-controls" style="margin-bottom:6px">
        <div id="city-metrics" class="fchips"></div>
        <select id="city-country"><option value="">All countries</option></select>
        <span id="city-count" class="sub" style="margin:0; align-self:center"></span>
      </div>
      <p id="city-note" class="sub" style="margin:2px 0 14px"></p>
      <div id="city-bars" class="bars"></div>

      <p class="method-note" style="margin-top:18px">
        <b>Source:</b> {cities.source} · <a href={cities.url} target="_blank" rel="noopener">Eurostat urb_percep</a> · {cities.license}. Top-2-box (strongly/very + somewhat/fairly).
      </p>
    </div>
  </section>

  <script type="application/json" id="city-data" set:html={JSON.stringify(cities)}></script>
  <script is:inline>
    (() => {
      const CITIES = JSON.parse(document.getElementById('city-data').textContent);
      const metricsEl = document.getElementById('city-metrics');
      const countryEl = document.getElementById('city-country');
      const barsEl = document.getElementById('city-bars');
      const noteEl = document.getElementById('city-note');
      const countEl = document.getElementById('city-count');
      let mi = 0;

      metricsEl.innerHTML = CITIES.metrics.map((m, i) =>
        `<button type="button" class="fchip${i === 0 ? ' active' : ''}" data-i="${i}">${m.label}</button>`).join('');
      const countries = [...new Set(CITIES.metrics.flatMap((m) => m.data.map((d) => d.country)))].sort();
      countryEl.innerHTML = '<option value="">All countries</option>' + countries.map((c) => `<option>${c}</option>`).join('');

      function render() {
        const m = CITIES.metrics[mi];
        const cc = countryEl.value;
        const rows = m.data.filter((d) => !cc || d.country === cc); // already sorted desc
        noteEl.textContent = m.summary;
        countEl.textContent = `${rows.length} cities`;
        const max = Math.max(100, ...rows.map((d) => d.value));
        const suffix = m.unit === '%' ? '%' : '';
        barsEl.innerHTML = rows.map((d, i) => `
          <div class="bar-row">
            <span title="${d.country}"><em style="color:var(--text-dim);font-style:normal">${i + 1}.</em> ${d.city} <em style="color:var(--text-dim)">${d.cc}</em></span>
            <span class="bar-track"><span class="bar-fill" style="width:${(d.value / max) * 100}%"></span></span>
            <span class="bar-val">${d.value}${suffix}</span>
          </div>`).join('') || '<p class="sub">No cities.</p>';
      }
      metricsEl.addEventListener('click', (e) => {
        const b = e.target.closest('.fchip'); if (!b) return;
        mi = +b.dataset.i;
        [...metricsEl.children].forEach((c) => c.classList.toggle('active', c === b));
        render();
      });
      countryEl.addEventListener('change', render);
      render();
    })();
  </script>
</BaseLayout>
