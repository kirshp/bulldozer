---
import BaseLayout from '../layouts/BaseLayout.astro';
import DataPanel from '@components/DataPanel.astro';
import { getDataset } from '@data/datasets';
import companies from '@data/companies.json';
import brands from '@data/brands.json';
import isoAlpha2 from '@data/iso-alpha2.json';
import { flagFor } from '@lib/flags';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const A2: Record<string, string> = isoAlpha2 as Record<string, string>;
const regionNames = new Intl.DisplayNames(['en'], { type: 'region' });
const countryName = (iso?: string | null) => { if (!iso) return iso || ''; try { return A2[iso] ? regionNames.of(A2[iso])! : iso; } catch { return iso; } };
/** Unique countries present, most-frequent first, with display name. */
const countryList = (items: { iso?: string | null }[]) => {
  const count = new Map<string, number>();
  for (const it of items) if (it.iso) count.set(it.iso, (count.get(it.iso) || 0) + 1);
  return [...count.entries()].sort((a, b) => b[1] - a[1]).map(([iso, n]) => ({ iso, name: countryName(iso), n }));
};
const coCountries = countryList(companies);
const brCountries = countryList(brands);

const MARKET = ['wb-market-cap-share', 'wb-market-cap', 'forbes-global-2000', 'brandz-value', 'brandz-count', 'wb-stocks-traded', 'wb-listed-companies'];
const FINANCE = ['wb-account-ownership', 'wb-digital-payments', 'wb-mobile-money', 'wb-debit-card', 'wb-bank-branches'];
const slugs = [...MARKET, ...FINANCE].filter((s) => getDataset(s));
const panelIndicators = slugs.map((s) => {
  const d = getDataset(s)!;
  return { slug: d.slug, title: d.title, kind: d.kind, unit: d.unit, valueLabel: d.valueLabel, changeMode: d.changeMode, periods: [...new Set(d.data.map((o) => o.period))].sort() };
});
const card = (s: string) => { const d = getDataset(s)!; return { slug: d.slug, title: d.title, source: d.source, summary: d.summary }; };

// Company bar chart is client-rendered with a metric switcher.
const coData = companies.map((c) => ({ name: c.name, flag: flagFor(c.iso), logo: c.logo, capBn: c.capBn, capYear: c.capYear, revenueBn: c.revenueBn, profitBn: c.profitBn, employees: c.employees, revYear: c.revYear }));
const brBars = brands.filter((b) => b.valueBn).slice(0, 12);
const brMax = Math.max(1, ...brBars.map((b) => b.valueBn));
const usd = (bn: number) => (bn >= 1000 ? '$' + (bn / 1000).toFixed(2) + ' tn' : '$' + bn + ' bn');

const RANKINGS = [
  { name: 'Interbrand — Best Global Brands', url: 'https://interbrand.com/best-global-brands/', note: 'Top-100 brands by estimated brand value.' },
  { name: 'Kantar BrandZ — Most Valuable Brands', url: 'https://www.kantar.com/campaigns/brandz', note: 'Annual most-valuable-brands ranking.' },
  { name: 'Brand Finance — Global 500', url: 'https://brandfinance.com/insights/global-500-2024', note: 'Brand value across 500 companies.' },
  { name: 'Fortune — Global 500', url: 'https://fortune.com/ranking/global500/', note: 'Largest companies by revenue.' },
  { name: 'Forbes — Global 2000', url: 'https://www.forbes.com/lists/global2000/', note: 'Largest public companies.' },
];
---
<BaseLayout title="Companies & brand data" active="markets">
  <section class="section" id="top">
    <div class="container">
      <nav class="explore-nav">
        <a class="ghost-btn" href="#data">📊 By country</a>
        <a class="ghost-btn" href="#companies">🏢 Companies</a>
        <a class="ghost-btn" href="#brands">™️ Brands</a>
        <a class="ghost-btn" href="#rankings">🔗 Rankings</a>
      </nav>
      <span class="kicker">Companies & brands</span>
      <h2>Companies &amp; brand data</h2>
      <p class="page-tagline">Mine the data for the profit.</p>
      <p class="sub" style="max-width:700px">
        Stock-market capitalisation by country, the largest companies by revenue and the
        most valuable brands by estimated value — each with a directory and source links.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top:0" id="data">
    <div class="container">
      <h2>Markets by country</h2>
      <p class="sub">Stock-market capitalisation, listings, biggest-company & brand counts and financial-service usage — pick any indicator.</p>
      <DataPanel indicators={panelIndicators} defaultView="bubbles" />
    </div>
  </section>

  <section class="section" style="padding-top:0" id="companies">
    <div class="container">
      <h2>Largest companies</h2>
      <div class="ci-controls" style="margin-bottom:6px; display:flex; gap:10px 14px; flex-wrap:wrap; align-items:center">
        <span class="view-toggle" id="co-view">
          <button type="button" data-v="slope" class="active">Cap × revenue</button>
          <button type="button" data-v="bars">Bars</button>
        </span>
        <span class="view-toggle" id="co-sort">
          <button type="button" data-s="cap" class="active">Market cap first</button>
          <button type="button" data-s="rev">Revenue first</button>
        </span>
        <span class="view-toggle" id="co-metric" style="display:none">
          <button type="button" data-m="capBn" class="active">Market cap</button>
          <button type="button" data-m="revenueBn">Revenue</button>
          <button type="button" data-m="profitBn">Profit</button>
          <button type="button" data-m="employees">Employees</button>
        </span>
        <label class="co-all" id="co-all-wrap"><input type="checkbox" id="co-all-cb"> <span id="co-all-txt">Show all</span></label>
      </div>

      <div class="co-slope" id="co-slope">
        <p class="co-slope-hero" id="co-slope-hero"></p>
        <div class="co-slope-heads"><span id="co-slope-hl"></span><span id="co-slope-hr"></span></div>
        <div class="co-slope-plot">
          <svg id="co-slope-svg" viewBox="0 0 920 520" role="img" aria-label="Ribbon slope: market-cap rank versus revenue rank"></svg>
          <div class="tip" id="co-slope-tip"></div>
        </div>
        <p class="co-slope-foot" id="co-slope-foot"></p>
      </div>

      <p class="sub" id="co-bar-sub" style="display:none"></p>
      <div class="bars" id="co-bars" style="display:none"></div>
      <script type="application/json" id="co-data" set:html={JSON.stringify(coData)}></script>

      <h3 style="margin-top:26px">Company directory</h3>
      <p class="sub">All {companies.length} — name, logo, country, industry and a one-line profile. Click through to the source.</p>
      <div class="ci-controls dir-controls">
        <input class="dir-search" type="search" placeholder="Filter companies…" autocomplete="off" />
        <select class="dir-sort">
          <option value="best">Largest first</option>
          <option value="name">Name A–Z</option>
          <option value="country">By country</option>
        </select>
        <select class="dir-country">
          <option value="">All countries</option>
          {coCountries.map((c) => <option value={c.iso}>{flagFor(c.iso)} {c.name} ({c.n})</option>)}
        </select>
        <span class="view-toggle dir-views">
          <button type="button" data-n="3" class="active">Top 3</button>
          <button type="button" data-n="10">Top 10</button>
          <button type="button" data-n="0">All</button>
        </span>
      </div>
      <div class="company-grid" style="margin-top:10px">
        {companies.map((c) => (
          <a class="company-card" href={c.wiki} target="_blank" rel="noopener" data-name={c.name.toLowerCase()} data-country={c.iso || ''}>
            <span class="co-logo">{c.logo ? <img src={`${c.logo}?width=80`} alt="" loading="lazy" /> : <span class="co-mono">{c.name.slice(0, 1)}</span>}</span>
            <span class="co-info">
              <strong>{flagFor(c.iso)} {c.name}</strong>
              <span class="co-val">
                {c.capBn && <b>{usd(c.capBn)} cap · {c.capYear}</b>}
                {c.revenueBn && <span>{usd(c.revenueBn)} revenue · {c.revYear}</span>}
              </span>
              {c.industry && <span class="co-ind">{c.industry}</span>}
              {c.desc && <span class="co-desc">{c.desc}</span>}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section" style="padding-top:0" id="brands">
    <div class="container">
      <h2>Most valuable brands</h2>
      <p class="sub">Top {brBars.length} by estimated value · Kantar BrandZ {brBars[0]?.year}.</p>
      <div class="bars">
        {brBars.map((b) => (
          <div class="bar-row">
            <span class="bar-label">
              <span class="bar-logo">{b.logo ? <img src={`${b.logo}?width=48`} alt="" loading="lazy" /> : <span class="co-mono">{b.name.slice(0, 1)}</span>}</span>
              {flagFor(b.iso)} {b.name}
            </span>
            <span class="bar-track"><span class="bar-fill br-bar" style={`width:${Math.round((b.valueBn / brMax) * 100)}%`}></span></span>
            <span class="bar-val">{usd(b.valueBn)}</span>
          </div>
        ))}
      </div>

      <h3 style="margin-top:26px">Brand directory</h3>
      <p class="sub">All {brands.length} — name, logo, country of origin and one-line profile.</p>
      <div class="ci-controls dir-controls">
        <input class="dir-search" type="search" placeholder="Filter brands…" autocomplete="off" />
        <select class="dir-sort">
          <option value="best">Most valuable first</option>
          <option value="name">Name A–Z</option>
          <option value="country">By country</option>
        </select>
        <select class="dir-country">
          <option value="">All countries</option>
          {brCountries.map((c) => <option value={c.iso}>{flagFor(c.iso)} {c.name} ({c.n})</option>)}
        </select>
        <span class="view-toggle dir-views">
          <button type="button" data-n="3" class="active">Top 3</button>
          <button type="button" data-n="10">Top 10</button>
          <button type="button" data-n="0">All</button>
        </span>
      </div>
      <div class="company-grid" style="margin-top:10px">
        {brands.map((b) => (
          <a class="company-card" href={b.wiki} target="_blank" rel="noopener" data-name={b.name.toLowerCase()} data-country={b.iso || ''}>
            <span class="co-logo">{b.logo ? <img src={`${b.logo}?width=80`} alt="" loading="lazy" /> : <span class="co-mono">{b.name.slice(0, 1)}</span>}</span>
            <span class="co-info">
              <strong>{flagFor(b.iso)} {b.name}</strong>
              <span class="co-ind">{usd(b.valueBn)} brand value · {b.year}</span>
              {b.desc && <span class="co-desc">{b.desc}</span>}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section" style="padding-top:0" id="rankings">
    <div class="container">
      <h2>Brand &amp; company rankings (external)</h2>
      <p class="sub">Published by commercial research firms; brand-value figures are proprietary, so we link out.</p>
      <div class="grid cols-2">
        {RANKINGS.map((r) => (
          <a class="card link" href={r.url} target="_blank" rel="noopener">
            <h3 style="font-size:15px">{r.name} ↗</h3>
            <p class="meta">{r.note}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <script>
    function initDir(id) {
      const sec = document.getElementById(id);
      if (!sec) return;
      const grid = sec.querySelector('.company-grid');
      const cards = Array.prototype.slice.call(grid.children);
      cards.forEach((c, i) => (c._i = i));
      const search = sec.querySelector('.dir-search');
      const sortSel = sec.querySelector('.dir-sort');
      const countrySel = sec.querySelector('.dir-country');
      const views = sec.querySelector('.dir-views');
      let limit = 3;
      function render() {
        const q = search.value.trim().toLowerCase();
        const ctry = countrySel.value;
        let list = cards.filter((c) =>
          (!q || c.dataset.name.indexOf(q) >= 0 || (c.dataset.country || '').toLowerCase().indexOf(q) >= 0) &&
          (!ctry || c.dataset.country === ctry));
        const s = sortSel.value;
        if (s === 'name') list.sort((a, b) => a.dataset.name.localeCompare(b.dataset.name));
        else if (s === 'country') list.sort((a, b) => (a.dataset.country || 'zz').localeCompare(b.dataset.country || 'zz') || a._i - b._i);
        else list.sort((a, b) => a._i - b._i);
        const limited = limit > 0 ? list.slice(0, limit) : list;
        const shown = new Set(limited);
        limited.forEach((c) => grid.appendChild(c));
        cards.forEach((c) => (c.style.display = shown.has(c) ? '' : 'none'));
      }
      search.addEventListener('input', render);
      sortSel.addEventListener('change', render);
      countrySel.addEventListener('change', render);
      views.addEventListener('click', (e) => {
        const b = e.target.closest('button'); if (!b) return;
        limit = Number(b.dataset.n);
        Array.prototype.forEach.call(views.children, (x) => x.classList.toggle('active', x === b));
        render();
      });
      render();
    }
    initDir('companies');
    initDir('brands');

    // Company bar chart with a metric switcher (market cap / revenue / profit / employees).
    (function () {
      const data = JSON.parse(document.getElementById('co-data').textContent);
      const bars = document.getElementById('co-bars');
      const sub = document.getElementById('co-bar-sub');
      const toggle = document.getElementById('co-metric');
      const usd = (bn) => (bn >= 1000 ? '$' + (bn / 1000).toFixed(2) + ' tn' : (bn <= -1000 ? '-$' + (-bn / 1000).toFixed(2) + ' tn' : '$' + bn + ' bn'));
      const META = {
        capBn: { label: 'market capitalisation', fmt: usd, yr: (c) => c.capYear, note: 'Source: companiesmarketcap.com via Wikipedia.' },
        revenueBn: { label: 'revenue', fmt: usd, yr: (c) => c.revYear, note: 'Source: Wikipedia / Wikidata.' },
        profitBn: { label: 'net profit', fmt: usd, yr: (c) => c.revYear, note: 'Source: Wikipedia / Wikidata.' },
        employees: { label: 'employees', fmt: (n) => n.toLocaleString('en-US'), yr: (c) => c.revYear, note: 'Source: Wikipedia / Wikidata.' },
      };
      function render(metric) {
        const m = META[metric];
        const list = data.filter((c) => c[metric] != null).sort((a, b) => b[metric] - a[metric]).slice(0, 12);
        const max = Math.max(1, ...list.map((c) => Math.abs(c[metric])));
        sub.textContent = `Top ${list.length} by ${m.label} · ${m.yr(list[0]) || ''}. ${m.note}`;
        bars.innerHTML = list.map((c) => {
          const w = Math.round((Math.abs(c[metric]) / max) * 100);
          const logo = c.logo ? `<span class="bar-logo"><img src="${c.logo}?width=48" alt="" loading="lazy"></span>` : `<span class="bar-logo"><span class="co-mono">${c.name.slice(0, 1)}</span></span>`;
          return `<div class="bar-row"><span class="bar-label">${logo}${c.flag}${c.name}</span><span class="bar-track"><span class="bar-fill co-bar" style="width:${w}%"></span></span><span class="bar-val">${m.fmt(c[metric])}</span></div>`;
        }).join('');
      }
      toggle.addEventListener('click', (e) => {
        const b = e.target.closest('button'); if (!b) return;
        Array.prototype.forEach.call(toggle.children, (x) => x.classList.toggle('active', x === b));
        render(b.dataset.m);
      });
      render('capBn');

      // ---- default view: cap × revenue ribbon slope (per Claude Design) ----
      const viewT = document.getElementById('co-view');
      const sortT = document.getElementById('co-sort');
      const metricT = document.getElementById('co-metric');
      const slopeBox = document.getElementById('co-slope');
      const svg = document.getElementById('co-slope-svg');
      const tip = document.getElementById('co-slope-tip');
      const heroEl = document.getElementById('co-slope-hero');
      const hlEl = document.getElementById('co-slope-hl');
      const hrEl = document.getElementById('co-slope-hr');
      const footEl = document.getElementById('co-slope-foot');
      const NSU = 'http://www.w3.org/2000/svg';
      const mk = (t, a, txt) => { const e = document.createElementNS(NSU, t); for (const k in a) e.setAttribute(k, a[k]); if (txt != null) e.textContent = txt; return e; };
      const ord = (n) => { const s = ['th', 'st', 'nd', 'rd'], v = n % 100; return n + (s[(v - 20) % 10] || s[v] || s[0]); };

      // every company that has both a cap and a revenue, biggest cap first
      const POOL = data.filter((c) => c.capBn != null && c.revenueBn != null)
        .sort((a, b) => b.capBn - a.capBn)
        .map((c) => ({ name: c.name, cap: c.capBn, rev: c.revenueBn, capYear: c.capYear, revYear: c.revYear, flag: c.flag, logo: c.logo }));
      const VBW = 920, topPad = 12, xL = 8, xR = 912, ctrl = 460, rowH = 40;
      const metricLabel = (k) => (k === 'cap' ? 'market cap' : 'revenue');
      const headerLabel = (k) => (k === 'cap' ? 'Rank by market cap' : 'Rank by revenue');
      let sort = 'cap', hov = null, showAll = false;

      function slopeRender() {
        const S = showAll ? POOL : POOL.slice(0, 10);
        const N = S.length;
        const VBH = topPad * 2 + 14 + (N - 1) * rowH;
        const yOf = (i) => topPad + i * rowH + 7;
        const maxVal = Math.max(...S.map((c) => Math.max(c.cap, c.rev)));
        const wOf = (v) => 2.5 + 21 * Math.sqrt(v / maxVal);
        svg.setAttribute('viewBox', `0 0 ${VBW} ${VBH}`);
        const leftKey = sort === 'cap' ? 'cap' : 'rev';
        const rightKey = sort === 'cap' ? 'rev' : 'cap';
        const byLeft = [...S].sort((a, b) => b[leftKey] - a[leftKey]);
        const byRight = [...S].sort((a, b) => b[rightKey] - a[rightKey]);
        const hero = byLeft[0].name;
        const rows = S.map((c) => {
          const li = byLeft.findIndex((d) => d.name === c.name);
          const ri = byRight.findIndex((d) => d.name === c.name);
          return { c, li, ri, yl: yOf(li), yr: yOf(ri) };
        });
        svg.innerHTML = '';
        // ribbons — widest drawn first so thin ones stay legible on top
        const ribs = rows.map((r) => {
          const isHero = r.c.name === hero, isHov = hov === r.c.name;
          const wl = wOf(r.c[leftKey]) / 2, wr = wOf(r.c[rightKey]) / 2;
          const x1 = xL + 6, x2 = xR;
          const path = `M ${x1} ${r.yl - wl} C ${ctrl} ${r.yl - wl}, ${ctrl} ${r.yr - wr}, ${x2} ${r.yr - wr} L ${x2} ${r.yr + wr} C ${ctrl} ${r.yr + wr}, ${ctrl} ${r.yl + wl}, ${x1} ${r.yl + wl} Z`;
          return { r, path, w: wl + wr, on: isHero || isHov,
            fill: (isHero || isHov) ? 'var(--accent)' : 'var(--rib)',
            opacity: hov && !isHov && !isHero ? 0.28 : ((isHero || isHov) ? 0.96 : 0.6) };
        }).sort((a, b) => b.w - a.w);
        ribs.forEach((rb) => {
          const p = mk('path', { d: rb.path, fill: rb.fill, opacity: rb.opacity, 'data-n': rb.r.c.name, style: 'cursor:pointer; transition:opacity .15s, fill .15s;' });
          svg.appendChild(p);
        });
        // end ticks
        rows.forEach((r) => {
          const on = r.c.name === hero || r.c.name === hov;
          const hl = Math.max(10, wOf(r.c[leftKey]) + 4), hr = Math.max(10, wOf(r.c[rightKey]) + 4);
          svg.appendChild(mk('rect', { x: xL, y: r.yl - hl / 2, width: 6, height: hl, fill: on ? 'var(--accent)' : 'var(--tickc)', 'data-n': r.c.name }));
          svg.appendChild(mk('rect', { x: xR, y: r.yr - hr / 2, width: 6, height: hr, fill: on ? 'var(--accent)' : 'var(--tickc)', 'data-n': r.c.name }));
        });
        // labels — top-3 each side, plus hero and any hovered line
        rows.forEach((r) => {
          const on = r.c.name === hero || r.c.name === hov;
          const mkLab = (rank, y, key, side) => {
            const name = r.c.name, val = usd(r.c[key]);
            const yr = key === 'cap' ? r.c.capYear : r.c.revYear;
            const anchor = side === 'L' ? 'start' : 'end';
            const x = side === 'L' ? xL + 16 : xR - 10;
            const g = mk('text', { x, y: y + 4, 'text-anchor': anchor, 'data-n': name, class: 'rib-lab' + (on ? ' on' : '') + (r.c.name === hero ? ' hero' : '') });
            const nm = mk('tspan', { class: 'rib-nm' }, name);
            const vl = mk('tspan', { class: 'rib-val', dx: 6 }, val);
            const yrSpan = yr ? mk('tspan', { class: 'rib-yr', dx: 4 }, "’" + String(yr).slice(2)) : null;
            // order the tspans so name is always closest to the tick
            if (side === 'L') { g.append(nm, vl); if (yrSpan) g.append(yrSpan); }
            else { if (yrSpan) g.append(yrSpan); g.append(vl, nm); }
            svg.appendChild(g);
          };
          mkLab(r.li, r.yl, leftKey, 'L');
          mkLab(r.ri, r.yr, rightKey, 'R');
        });
        // wire interactions
        svg.querySelectorAll('[data-n]').forEach((node) => {
          const nm = node.getAttribute('data-n'); const c = S.find((x) => x.name === nm);
          node.addEventListener('mousemove', (e) => { if (hov !== nm) { hov = nm; slopeRender(); } slopeTip(c, e); });
          node.addEventListener('mouseleave', () => { hov = null; slopeRender(); tip.style.opacity = 0; });
        });
        // headers double as the sort control (click a column to put it first)
        hlEl.textContent = headerLabel(leftKey); hlEl.dataset.metric = leftKey;
        hrEl.textContent = headerLabel(rightKey); hrEl.dataset.metric = rightKey;
        hlEl.classList.add('hd-click', 'first'); hrEl.classList.add('hd-click'); hrEl.classList.remove('first');
        const heroRow = rows.find((r) => r.c.name === hero);
        heroEl.innerHTML = `<span class="hero-co">${hero}</span> ranks <strong>1st</strong> in ${metricLabel(leftKey)}… and <strong>${ord(heroRow.ri + 1)}</strong> in ${metricLabel(rightKey)} among the world’s giants.`;
        footEl.textContent = `${N} of the world’s largest public companies, ranked among themselves. Ribbon width = size. Hover a line for detail. Market cap 2026 · revenue latest FY/TTM.`;
      }
      function slopeTip(c, e) {
        const box = svg.parentElement.getBoundingClientRect();
        tip.innerHTML = `<b>${c.flag || ''} ${c.name}</b><br>Cap ${usd(c.cap)} &nbsp;|&nbsp; Revenue ${usd(c.rev)}`;
        tip.style.left = (e.clientX - box.left) + 'px'; tip.style.top = (e.clientY - box.top) + 'px'; tip.style.opacity = 1;
      }
      function setSort(m) {
        sort = m; hov = null;
        Array.prototype.forEach.call(sortT.children, (x) => x.classList.toggle('active', x.dataset.s === m));
        slopeRender();
      }
      sortT.addEventListener('click', (e) => { const b = e.target.closest('button'); if (b) setSort(b.dataset.s); });
      hlEl.addEventListener('click', () => setSort(hlEl.dataset.metric));
      hrEl.addEventListener('click', () => setSort(hrEl.dataset.metric));
      const allWrap = document.getElementById('co-all-wrap');
      const allCb = document.getElementById('co-all-cb');
      document.getElementById('co-all-txt').textContent = `Show all ${POOL.length}`;
      allCb.addEventListener('change', () => { showAll = allCb.checked; hov = null; slopeRender(); });
      viewT.addEventListener('click', (e) => {
        const b = e.target.closest('button'); if (!b) return;
        Array.prototype.forEach.call(viewT.children, (x) => x.classList.toggle('active', x === b));
        const slope = b.dataset.v === 'slope';
        slopeBox.style.display = slope ? '' : 'none';
        sortT.style.display = slope ? '' : 'none';
        allWrap.style.display = slope ? '' : 'none';
        metricT.style.display = slope ? 'none' : '';
        sub.style.display = slope ? 'none' : '';
        bars.style.display = slope ? 'none' : '';
      });
      slopeRender();
    })();
  </script>
</BaseLayout>
