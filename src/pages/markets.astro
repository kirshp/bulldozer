---
import BaseLayout from '../layouts/BaseLayout.astro';
import DataPanel from '@components/DataPanel.astro';
import { datasets, getDataset } from '@data/datasets';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Curated set of OPEN, country-level market & financial-service indicators.
const MARKET = ['wb-market-cap', 'wb-stocks-traded', 'wb-listed-companies'];
const FINANCE = ['wb-account-ownership', 'wb-digital-payments', 'wb-mobile-money', 'wb-debit-card', 'wb-bank-branches'];
const slugs = [...MARKET, ...FINANCE].filter((s) => getDataset(s));
const panelIndicators = slugs.map((s) => {
  const d = getDataset(s)!;
  return {
    slug: d.slug, title: d.title, kind: d.kind, unit: d.unit, valueLabel: d.valueLabel,
    changeMode: d.changeMode, periods: [...new Set(d.data.map((o) => o.period))].sort(),
  };
});
const card = (s: string) => { const d = getDataset(s)!; return { slug: d.slug, title: d.title, source: d.source, summary: d.summary }; };

// External brand/company rankings — proprietary, so we link rather than host.
const RANKINGS = [
  { name: 'Interbrand — Best Global Brands', url: 'https://interbrand.com/best-global-brands/', note: 'Top-100 brands by estimated brand value.' },
  { name: 'Kantar BrandZ — Most Valuable Brands', url: 'https://www.kantar.com/campaigns/brandz', note: 'Annual most-valuable-brands ranking.' },
  { name: 'Brand Finance — Global 500', url: 'https://brandfinance.com/insights/global-500-2024', note: 'Brand value across 500 companies.' },
  { name: 'Fortune — Global 500', url: 'https://fortune.com/ranking/global500/', note: 'Largest companies by revenue.' },
  { name: 'Forbes — Global 2000', url: 'https://www.forbes.com/lists/global2000/', note: 'Largest public companies (sales, profit, assets, market value).' },
];
---
<BaseLayout title="Markets" active="markets" description="Open, country-level data on stock markets, listed companies and financial services — plus links to the major brand and company rankings.">
  <section class="section">
    <div class="container">
      <span class="kicker">Markets & companies</span>
      <h2>Markets &amp; companies</h2>
      <p class="sub" style="max-width:680px">
        The open, country-comparable view of company life: how deep each country’s stock
        market is, how many companies are listed, and how widely people use financial
        services. Brand- and company-value rankings are proprietary — linked below.
      </p>
      <DataPanel indicators={panelIndicators} />
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      <h2>Stock markets</h2>
      <p class="sub">Market depth and listings, by country.</p>
      <div class="grid cols-3">
        {MARKET.filter((s) => getDataset(s)).map((s) => { const d = card(s); return (
          <a class="card link" href={`${base}/dataset/${d.slug}`}>
            <h3 style="font-size:16px">{d.title}</h3>
            <p class="meta">{d.summary}</p>
            <span class="pill">{d.source}</span>
          </a>
        ); })}
      </div>
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      <h2>Financial services &amp; fintech</h2>
      <p class="sub">Who uses accounts, cards, digital and mobile money.</p>
      <div class="grid cols-3">
        {FINANCE.filter((s) => getDataset(s)).map((s) => { const d = card(s); return (
          <a class="card link" href={`${base}/dataset/${d.slug}`}>
            <h3 style="font-size:16px">{d.title}</h3>
            <p class="meta">{d.summary}</p>
            <span class="pill">{d.source}</span>
          </a>
        ); })}
      </div>
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      <h2>Brand &amp; company rankings</h2>
      <p class="sub">
        These are published by commercial research firms and their brand-value figures are
        proprietary, so we link out rather than redistribute them.
      </p>
      <div class="grid cols-2">
        {RANKINGS.map((r) => (
          <a class="card link" href={r.url} target="_blank" rel="noopener">
            <h3 style="font-size:15px">{r.name} ↗</h3>
            <p class="meta">{r.note}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
