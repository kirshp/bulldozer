---
import BaseLayout from '../layouts/BaseLayout.astro';
import { sources, sourceCategories } from '@data/sources';
import { datasets } from '@data/datasets';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function liveCount(match?: string) {
  if (!match) return 0;
  return datasets.filter((d) => d.source.includes(match)).length;
}
const liveTotal = sources.filter((s) => s.status === 'live').length;
const catalogTotal = sources.filter((s) => s.status === 'catalog').length;
---
<BaseLayout title="Sources" active="sources" description="Catalogue of survey programmes and data sources gathered for BullDozer — each with an official link and a short description.">
  <section class="section">
    <div class="container">
      <span class="kicker">The collection</span>
      <h2>Sources &amp; surveys</h2>
      <p class="sub">
        Every programme we have gathered, with an official link and a short description.
        <b>{liveTotal}</b> are live in BullDozer ({datasets.length} datasets); <b>{catalogTotal}</b> more are
        catalogued — collected and documented, available as microdata or on request from the source.
      </p>

      {sourceCategories.map((cat) => (
        <div style="margin-top:32px">
          <h3 style="margin:0 0 14px">{cat}</h3>
          <div class="grid cols-2">
            {sources.filter((s) => s.category === cat).map((s) => {
              const n = liveCount(s.match);
              return (
                <div class="card source-card">
                  <div class="source-head">
                    <h3><a href={s.url} target="_blank" rel="noopener">{s.name} ↗</a></h3>
                    {s.status === 'live'
                      ? <span class="badge live">Live · {n} {n === 1 ? 'dataset' : 'datasets'}</span>
                      : <span class="badge catalog">Catalogue</span>}
                  </div>
                  <p class="meta">{s.description}</p>
                  {s.status === 'live' && <p class="meta"><a href={`${base}/explore`}>Explore data →</a></p>}
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
