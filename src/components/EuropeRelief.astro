---
/**
 * "Europe in relief" — the familiar flat Europe choropleth with a gentle
 * 3-D lift for /macro. Height of each country = GDP per capita (PPP);
 * colour = happiness (WHR), same blue ramp as the flat map. Built from raw
 * world-atlas geometry (overseas territories clipped away), projected with
 * the flat map's conic projection, then extruded a few pixels by stacking
 * translated rings. Every country's top face is hoverable for its numbers.
 * Our own render — not traced from any atlas.
 */
import { readFileSync } from 'node:fs';
import { createRequire } from 'node:module';
import { feature } from 'topojson-client';
import { geoConicConformal, geoCentroid } from 'd3-geo';
import isoNumericJson from '@data/iso-numeric.json';
import gdpJson from '@data/macro/imf-gdp-per-capita-ppp.json';
import whrJson from '@data/surveys/whr-happiness.json';

const require = createRequire(import.meta.url);
const topo = JSON.parse(readFileSync(require.resolve('world-atlas/countries-110m.json'), 'utf8'));
const fc: any = feature(topo, (topo as any).objects.countries);
const isoNumeric: Record<string, string> = isoNumericJson as any;

const latest = (d: any) => { const p = [...new Set(d.data.map((o: any) => o.period))].sort(); return p[p.length - 1]; };
const gP = latest(gdpJson), wP = latest(whrJson);
const gByIso = new Map<string, number>((gdpJson.data as any[]).filter((o) => o.period === gP && o.iso).map((o) => [o.iso, o.value]));
const wByIso = new Map<string, number>((whrJson.data as any[]).filter((o) => o.period === wP && o.iso).map((o) => [o.iso, o.value]));

const BB = { lo0: -25, lo1: 45, la0: 34, la1: 71.5 };
const inBB = (lo: number, la: number) => lo >= BB.lo0 && lo <= BB.lo1 && la >= BB.la0 && la <= BB.la1;
const centr = (r: number[][]): [number, number] => { let x = 0, y = 0; for (const p of r) { x += p[0]; y += p[1]; } return [x / r.length, y / r.length]; };
function euRings(f: any): number[][][] {
  const g = f.geometry, polys = g.type === 'Polygon' ? [g.coordinates] : g.coordinates;
  return polys.map((p: any) => p[0]).filter((r: number[][]) => inBB(...centr(r)));
}
const raw = fc.features
  .filter((f: any) => inBB(...(geoCentroid(f) as [number, number])))
  .map((f: any) => ({ f, a3: isoNumeric[String(Number(f.id))], rings: euRings(f) }))
  .filter((o: any) => o.rings.length);

const W = 1160, H = 720, TILT = 0.92, MAXH = 26, MINH = 3, M = 44;
const allPts: number[][] = raw.flatMap((o: any) => o.rings.flat());
// Same conic projection as the flat Europe map, so the shape reads "as before".
const proj = geoConicConformal().parallels([43, 62]).rotate([-13, 0])
  .fitExtent([[M, M + MAXH], [W - M, H - M]], { type: 'MultiPoint', coordinates: allPts } as any);
const projYs = allPts.map((ll) => proj(ll as any)![1]);
const yMid = (Math.min(...projYs) + Math.max(...projYs)) / 2;
const T = ([x, y]: [number, number]): [number, number] => [x, yMid + (y - yMid) * TILT];

const gVals = raw.map((o: any) => gByIso.get(o.a3)).filter((v: any) => v != null) as number[];
const gMin = Math.min(...gVals), gMax = Math.max(...gVals);
const heightOf = (g?: number) => (g == null ? 0 : MINH + Math.pow((g - gMin) / (gMax - gMin), 0.7) * (MAXH - MINH));
const wVals = raw.map((o: any) => wByIso.get(o.a3)).filter((v: any) => v != null) as number[];
const wMin = Math.min(...wVals), wMax = Math.max(...wVals);
const lerp = (a: number[], b: number[], t: number) => a.map((v, i) => v + (b[i] - v) * t);
// Same look as the flat map: #3b82f6 blue whose strength tracks happiness,
// pre-blended against the light paper stage into solid fills.
const PAPER = [243, 245, 250], BLUE = [59, 130, 246];
const rgb = (a: number[]) => `rgb(${Math.round(a[0])},${Math.round(a[1])},${Math.round(a[2])})`;
const topCol = (w?: number) => (w == null ? [225, 229, 237] : lerp(PAPER, BLUE, 0.16 + 0.72 * ((w - wMin) / (wMax - wMin))));
const r1 = (v: number) => Math.round(v * 10) / 10;

const recs = raw.map((o: any) => {
  const rings = o.rings.map((r: number[][]) => r.map((ll) => T(proj(ll as any)!)));
  const c = T(proj(geoCentroid(o.f) as any)!);
  return { name: o.f.properties.name, a3: o.a3, gdp: gByIso.get(o.a3), whr: wByIso.get(o.a3), rings, cx: c[0], cy: c[1] };
}).filter((r: any) => r.cy).sort((a: any, b: any) => a.cy - b.cy);

const SHORT: Record<string, string> = { 'United Kingdom': 'UK', 'Bosnia and Herz.': 'Bosnia', 'Czechia': 'Czechia', 'North Macedonia': 'N. Macedonia' };
const ringD = (rings: number[][][], dy: number) =>
  rings.map((rg) => 'M' + rg.map(([x, y]) => `${r1(x)},${r1(y + dy)}`).join('L') + 'Z').join('');

// build the extruded body (stacked rings) + a hoverable top face per country
let bodyHtml = '';
for (const r of recs) {
  const h = heightOf(r.gdp), tc = topCol(r.whr);
  // one solid, slightly darker shade for the whole wall — smooth, no banding
  const side = rgb(lerp(tc, [96, 114, 152], 0.55));
  const steps = Math.max(1, Math.round(h * 2));
  for (let i = 0; i < steps; i++) {
    bodyHtml += `<path class="er-body" d="${ringD(r.rings, -h * (i / steps))}" fill="${side}"/>`;
  }
  const name = SHORT[r.name] ?? r.name;
  const gTxt = r.gdp != null ? '$' + Math.round(r.gdp / 1000) + 'k' : '—';
  const wTxt = r.whr != null ? r.whr.toFixed(2) : '—';
  bodyHtml += `<path class="er-top" d="${ringD(r.rings, -h)}" fill="${rgb(tc)}" ` +
    `data-n="${name}" data-g="${gTxt}" data-w="${wTxt}"/>`;
}
// a few orienting labels, tallest-first with simple collision skip
const LABELS = ['Norway', 'Sweden', 'Ireland', 'Luxembourg', 'Switzerland', 'Germany', 'France', 'Spain', 'Poland', 'Ukraine', 'Turkey', 'United Kingdom', 'Italy', 'Romania'];
const boxes: number[][] = [];
const labels: { x: number; y: number; t: string }[] = [];
for (const r of [...recs].sort((a, b) => (b.gdp ?? 0) - (a.gdp ?? 0))) {
  if (!LABELS.includes(r.name) || r.gdp == null) continue;
  const h = heightOf(r.gdp), x = r.cx, y = r.cy - h - 4;
  const t = `${SHORT[r.name] ?? r.name} · $${Math.round(r.gdp / 1000)}k`;
  const w = t.length * 6.6;
  if (boxes.some((b) => Math.abs(x - b[0]) < (w + b[2]) / 2 + 2 && Math.abs(y - b[1]) < 14)) continue;
  boxes.push([x, y, w]); labels.push({ x, y, t });
}
---
<div class="er">
  <div class="er-wrap">
    <svg viewBox={`0 0 ${W} ${H}`} role="img" aria-label="Europe in relief — GDP per capita as height, happiness as colour" preserveAspectRatio="xMidYMid meet">
      <g class="er-scene" set:html={bodyHtml} />
      {labels.map((l) => (
        <text class="er-lab" x={r1(l.x)} y={r1(l.y)} text-anchor="middle">{l.t}</text>
      ))}
    </svg>
    <div id="er-tip" class="er-tip" hidden></div>
  </div>
  <div class="er-legend">
    <span class="er-key"><b>Height</b> · GDP per capita (PPP, {gP})</span>
    <span class="er-ramp" aria-hidden="true"></span>
    <span class="er-key"><b>Colour</b> · happiness (WHR {wP}) — muted → bright = less → more happy</span>
  </div>
</div>

<script is:inline>
  (() => {
    const wrap = document.querySelector('.er-wrap');
    if (!wrap) return;
    const svg = wrap.querySelector('svg');
    const tip = document.getElementById('er-tip');
    function move(e) {
      const el = e.target.closest('.er-top');
      if (!el) { tip.hidden = true; return; }
      tip.innerHTML = `<b>${el.dataset.n}</b>` +
        `<div class="tr"><span>GDP / capita</span><b>${el.dataset.g}</b></div>` +
        `<div class="tr"><span>Happiness</span><b>${el.dataset.w}</b></div>`;
      tip.hidden = false;
      const r = wrap.getBoundingClientRect();
      const x = e.clientX - r.left, y = e.clientY - r.top;
      tip.style.left = Math.min(x + 14, r.width - tip.offsetWidth - 6) + 'px';
      tip.style.top = Math.max(y - tip.offsetHeight - 10, 4) + 'px';
    }
    svg.addEventListener('mousemove', move);
    svg.addEventListener('mouseleave', () => { tip.hidden = true; });
  })();
</script>

<style>
  .er { margin: 10px 0 8px; }
  .er-wrap { position: relative; background: #f3f5fa; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
  .er-wrap svg { width: 100%; height: auto; display: block; }
  .er-body { pointer-events: none; }
  .er-top { cursor: pointer; stroke: rgba(255,255,255,0.8); stroke-width: 0.6; }
  .er-top:hover { stroke: #0f172a; stroke-width: 1.1; }
  .er-lab { fill: #1f2b46; font-size: 11.5px; font-weight: 700; paint-order: stroke; stroke: rgba(255,255,255,0.85); stroke-width: 2.6px; pointer-events: none; }
  .er-legend { display: flex; flex-wrap: wrap; align-items: center; gap: 6px 14px; margin-top: 10px; font-size: 12px; color: var(--text-dim); }
  .er-key b { color: var(--text); font-weight: 600; }
  .er-ramp { width: 90px; height: 10px; border-radius: 5px; display: inline-block; background: linear-gradient(90deg, rgb(214,227,247), rgb(81,144,246)); border: 1px solid var(--border); }
</style>

<style is:global>
  /* Tooltip body is written with innerHTML, so it must be global-scoped. */
  #er-tip {
    position: absolute; z-index: 6; pointer-events: none; min-width: 150px;
    background: var(--bg-card); border: 1px solid var(--border); border-radius: 8px;
    padding: 8px 10px; font-size: 12.5px; color: var(--text); box-shadow: 0 6px 22px rgba(0,0,0,0.4);
  }
  #er-tip .tr { display: flex; justify-content: space-between; gap: 16px; margin-top: 4px; color: var(--text-dim); }
  #er-tip .tr b { color: var(--text); font-family: var(--mono); }
</style>
