---
interface Point { x: string; y: number }
interface Props { points: Point[]; yLabel?: string; yMax?: number }
const { points, yLabel = '', yMax = 100 } = Astro.props;

const W = 760, H = 320, m = { t: 16, r: 20, b: 34, l: 40 };
const iw = W - m.l - m.r, ih = H - m.t - m.b;
const n = points.length;
const X = (i: number) => m.l + (n === 1 ? iw / 2 : (i / (n - 1)) * iw);
const Y = (v: number) => m.t + ih - (v / yMax) * ih;

const line = points.map((p, i) => `${i === 0 ? 'M' : 'L'}${X(i).toFixed(1)},${Y(p.y).toFixed(1)}`).join(' ');
const area = `${line} L${X(n - 1).toFixed(1)},${(m.t + ih).toFixed(1)} L${X(0).toFixed(1)},${(m.t + ih).toFixed(1)} Z`;
const yTicks = [0, 25, 50, 75, 100].filter((v) => v <= yMax);
const last = points[n - 1];
---
<div class="chart-svg">
  <svg viewBox={`0 0 ${W} ${H}`} role="img" aria-label={yLabel}>
    <defs>
      <linearGradient id="lc-fill" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="var(--accent)" stop-opacity="0.35" />
        <stop offset="100%" stop-color="var(--accent)" stop-opacity="0" />
      </linearGradient>
    </defs>
    {yTicks.map((v) => (
      <g>
        <line x1={m.l} y1={Y(v)} x2={W - m.r} y2={Y(v)} stroke="var(--border)" stroke-width="1" />
        <text x={m.l - 8} y={Y(v) + 4} text-anchor="end" class="axis">{v}</text>
      </g>
    ))}
    {points.map((p, i) => (i % Math.ceil(n / 8) === 0 || i === n - 1) && (
      <text x={X(i)} y={H - m.b + 20} text-anchor="middle" class="axis">{p.x}</text>
    ))}
    <path d={area} fill="url(#lc-fill)" />
    <path d={line} fill="none" stroke="var(--accent)" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round" />
    {points.map((p, i) => <circle cx={X(i)} cy={Y(p.y)} r={i === n - 1 ? 5 : 3} fill="var(--accent)" />)}
    <text x={X(n - 1) - 6} y={Y(last.y) - 10} text-anchor="end" class="pt-label" fill="var(--text)" style="font-weight:700">{last.y}%</text>
  </svg>
</div>
