---
// Country × indicator heatmap — cells coloured by global percentile, so a
// country's strengths and weaknesses across a topic are scannable at a glance.
import { TOPICS, TOPIC_ORDER } from '@lib/topics';
import isoAlpha2 from '@data/iso-alpha2.json';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const topicMeta = TOPIC_ORDER.map((id) => ({ id, label: TOPICS[id].label, icon: TOPICS[id].icon }));
const config = { base, topicMeta };
---
<div class="cheat">
  <div class="ci-controls">
    <label>Topic<select id="cheat-topic"></select></label>
    <label>Region<select id="cheat-region"><option value="">All regions</option></select></label>
    <label>Sort<select id="cheat-sort">
      <option value="mean">Best overall</option>
      <option value="meanAsc">Worst overall</option>
      <option value="name">Name A–Z</option>
    </select></label>
    <input id="cheat-search" class="dir-search" type="search" placeholder="Filter countries…" autocomplete="off" />
    <span class="view-toggle" id="cheat-views">
      <button type="button" data-n="10" class="active">Top 10</button>
      <button type="button" data-n="25">Top 25</button>
      <button type="button" data-n="0">All</button>
    </span>
  </div>
  <div class="corr-scroll" style="margin-top:10px"><table class="cheat-table" id="cheat-table"></table></div>
  <p class="sub" id="cheat-note" style="margin-top:10px">Each cell is coloured by the country’s global percentile on that indicator — green = top of the world, red = bottom.</p>
</div>
<script type="application/json" id="cheat-config" set:html={JSON.stringify(config)}></script>
<script type="application/json" id="cheat-a2" set:html={JSON.stringify(isoAlpha2)}></script>
<script>
  const cfg = JSON.parse(document.getElementById('cheat-config').textContent);
  const A2 = JSON.parse(document.getElementById('cheat-a2').textContent);
  const flag = (iso) => { const a2 = iso && A2[iso.toUpperCase()]; return a2 ? String.fromCodePoint(...[...a2].map((c) => 0x1f1e6 + c.charCodeAt(0) - 65)) + ' ' : ''; };
  const el = (id) => document.getElementById(id);
  const mix = (a, b, t) => a.map((x, i) => Math.round(x + (b[i] - x) * t));
  const GREY = [38, 41, 46], GREEN = [52, 211, 153], RED = [248, 113, 113];
  const fmt = (n) => Math.abs(n) >= 1000 ? n.toLocaleString('en-US', { maximumFractionDigits: 0 }) : n.toLocaleString('en-US', { maximumFractionDigits: 1 });
  const state = { topic: 'economy', region: '', q: '', sort: 'mean', limit: 10 };
  let countries = [];
  const perc = (it) => it.total > 1 ? (it.total - it.rank) / (it.total - 1) : 0.5;

  // ---- deep-link state from the URL ----
  const hq = new URLSearchParams(location.search);
  if (cfg.topicMeta.some((t) => t.id === hq.get('hmt'))) state.topic = hq.get('hmt');
  if (hq.get('hmr')) state.region = hq.get('hmr');
  if (['mean', 'meanAsc', 'name'].includes(hq.get('hms')) || (hq.get('hms') || '').startsWith('col:')) state.sort = hq.get('hms');
  if (['10', '25', '0'].includes(hq.get('hmn'))) state.limit = +hq.get('hmn');
  function syncUrl() {
    const p = new URLSearchParams(location.search);
    p.set('hmt', state.topic);
    if (state.region) p.set('hmr', state.region); else p.delete('hmr');
    if (state.sort !== 'mean') p.set('hms', state.sort); else p.delete('hms');
    if (state.limit !== 10) p.set('hmn', String(state.limit)); else p.delete('hmn');
    history.replaceState(null, '', location.pathname + '?' + p.toString() + location.hash);
  }

  el('cheat-topic').innerHTML = cfg.topicMeta.map((t) => `<option value="${t.id}">${t.icon} ${t.label}</option>`).join('');
  el('cheat-topic').value = state.topic;
  if (!state.sort.startsWith('col:')) el('cheat-sort').value = state.sort;
  Array.prototype.forEach.call(el('cheat-views').children, (b) => b.classList.toggle('active', +b.dataset.n === state.limit));

  function render() {
    // columns = indicators in the topic (union, ordered by title)
    const cols = new Map();
    for (const c of countries) for (const it of c.items) if (it.topic === state.topic && !cols.has(it.slug)) cols.set(it.slug, it.title);
    const colList = [...cols.entries()].sort((a, b) => a[1].localeCompare(b[1]));
    let rows = countries.filter((c) => (!state.region || c.region === state.region) && c.items.some((it) => it.topic === state.topic));
    if (state.q) rows = rows.filter((c) => c.name.toLowerCase().includes(state.q));
    const meanP = (c) => { const xs = c.items.filter((it) => it.topic === state.topic).map(perc); return xs.reduce((s, v) => s + v, 0) / (xs.length || 1); };
    const bySlug = (c, slug) => { const it = c.items.find((x) => x.slug === slug); return it ? perc(it) : -1; };
    if (state.sort === 'name') rows.sort((a, b) => a.name.localeCompare(b.name));
    else if (state.sort === 'meanAsc') rows.sort((a, b) => meanP(a) - meanP(b));
    else if (state.sort.startsWith('col:')) { const s = state.sort.slice(4); rows.sort((a, b) => bySlug(b, s) - bySlug(a, s)); }
    else rows.sort((a, b) => meanP(b) - meanP(a));
    const total = rows.length;
    if (state.q || state.sort === 'name') { /* show all when searching/alphabetical */ }
    else if (state.limit > 0) rows = rows.slice(0, state.limit);

    const sortedSlug = state.sort.startsWith('col:') ? state.sort.slice(4) : '';
    let html = '<thead><tr><th class="cheat-corner">Country</th>' + colList.map(([slug, t]) => `<th class="corr-col cheat-colhead" data-slug="${slug}" title="Sort by ${t}"><span>${slug === sortedSlug ? '▾ ' : ''}${t}</span></th>`).join('') + '</tr></thead><tbody>';
    for (const c of rows) {
      html += `<tr><th class="cheat-name">${flag(c.iso)}${c.name}</th>`;
      const byslug = new Map(c.items.map((it) => [it.slug, it]));
      for (const [slug] of colList) {
        const it = byslug.get(slug);
        if (!it) { html += '<td class="cheat-cell" style="background:var(--bg)"></td>'; continue; }
        const p = perc(it);
        const col = p >= 0.5 ? mix(GREY, GREEN, (p - 0.5) * 2) : mix(GREY, RED, (0.5 - p) * 2);
        const light = Math.abs(p - 0.5) > 0.32;
        html += `<td class="cheat-cell" style="background:rgb(${col[0]},${col[1]},${col[2]});color:${light ? '#0e0f11' : 'var(--text-dim)'}" title="${c.name} · ${it.title}: ${fmt(it.value)} (#${it.rank}/${it.total})">${fmt(it.value)}</td>`;
      }
      html += '</tr>';
    }
    el('cheat-table').innerHTML = html + '</tbody>';
    el('cheat-note').textContent = `Showing ${rows.length} of ${total} countries × ${colList.length} indicators · coloured by global percentile (green = top, red = bottom). Click a column header to sort by it.`;
  }

  el('cheat-topic').addEventListener('change', (e) => { state.topic = e.target.value; state.sort = 'mean'; el('cheat-sort').value = 'mean'; render(); syncUrl(); });
  el('cheat-region').addEventListener('change', (e) => { state.region = e.target.value; render(); syncUrl(); });
  el('cheat-search').addEventListener('input', (e) => { state.q = e.target.value.trim().toLowerCase(); render(); });
  el('cheat-sort').addEventListener('change', (e) => { state.sort = e.target.value; render(); syncUrl(); });
  el('cheat-views').addEventListener('click', (e) => { const b = e.target.closest('button'); if (!b) return; state.limit = +b.dataset.n; Array.prototype.forEach.call(el('cheat-views').children, (x) => x.classList.toggle('active', x === b)); render(); syncUrl(); });
  el('cheat-table').addEventListener('click', (e) => { const th = e.target.closest('.cheat-colhead'); if (!th) return; const s = 'col:' + th.dataset.slug; state.sort = state.sort === s ? 'mean' : s; el('cheat-sort').value = 'mean'; render(); syncUrl(); });

  fetch(`${cfg.base}/data/country-index.json`).then((r) => r.json()).then((d) => {
    countries = d;
    const regions = [...new Set(d.map((c) => c.region).filter(Boolean))].sort();
    el('cheat-region').innerHTML = '<option value="">All regions</option>' + regions.map((r) => `<option value="${r}">${r}</option>`).join('');
    if (state.region && !regions.includes(state.region)) state.region = '';
    el('cheat-region').value = state.region;
    render();
  });
</script>
