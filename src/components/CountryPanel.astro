---
import WorldMap from '@components/WorldMap.astro';
import isoNumeric from '@data/iso-numeric.json';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<div class="country-panel">
  <div class="controls">
    <label>Country<select id="country-sel"><option>Loading…</option></select></label>
  </div>

  <div class="country-card">
    <div class="cc-info">
      <h3 id="cc-name">—</h3>
      <p class="cc-extract" id="cc-extract"></p>
      <p class="country-desc" id="country-desc"></p>
    </div>
    <div class="cc-map" id="country-map"><WorldMap legendId="country-legend" showLegend={false} /></div>
  </div>

  <div id="country-items" style="margin-top:18px"></div>
</div>

<script type="application/json" id="cp-iso" set:html={JSON.stringify(isoNumeric)}></script>
<script define:vars={{ base }}>
  const isoNumeric = JSON.parse(document.getElementById('cp-iso').textContent);
  const numByIso = Object.fromEntries(Object.entries(isoNumeric).map(([n, a]) => [a, n]));
  const sel = document.getElementById('country-sel');
  const descEl = document.getElementById('country-desc');
  const itemsEl = document.getElementById('country-items');
  const mapEl = document.getElementById('country-map');
  const nameEl = document.getElementById('cc-name');
  const extractEl = document.getElementById('cc-extract');
  let countries = [];

  const fmt = (v, unit) => `${v.toLocaleString('en-US', { maximumFractionDigits: 1 })}${unit && unit.includes('%') ? '%' : ''}`;
  const find = (c, slug) => c.items.find((i) => i.slug === slug);

  // Wikipedia title aliases for names that differ from our datasets.
  const WIKI = { 'Russian Federation': 'Russia', 'Korea, Rep.': 'South Korea', 'Iran, Islamic Rep.': 'Iran', 'Egypt, Arab Rep.': 'Egypt', 'Venezuela, RB': 'Venezuela', 'Viet Nam': 'Vietnam', 'Türkiye, Republic of': 'Turkey', 'Czechia': 'Czech Republic', 'Slovak Republic': 'Slovakia', 'Lao PDR': 'Laos', 'Syrian Arab Republic': 'Syria' };

  function describe(c) {
    const bits = [];
    const gdp = find(c, 'imf-gdp-per-capita-ppp') || find(c, 'imf-gdp-per-capita');
    const life = find(c, 'gapminder-life-expectancy');
    const happy = find(c, 'whr-happiness');
    const dem = find(c, 'v-dem-v2x-libdem');
    if (gdp) bits.push(`GDP per capita ${Math.round(gdp.value).toLocaleString()} ${gdp.unit} (#${gdp.rank})`);
    if (life) bits.push(`life expectancy ${life.value} yrs`);
    if (happy) bits.push(`happiness ${happy.value} (#${happy.rank})`);
    if (dem) bits.push(`liberal-democracy ${dem.value} (#${dem.rank})`);
    return `${c.region || 'World'}. ${bits.join(' · ')}.`;
  }

  function renderItems(c) {
    const groups = { macro: [], survey: [] };
    for (const it of c.items) (groups[it.kind] || groups.survey).push(it);
    const block = (label, arr) => arr.length ? `<h3 style="font-size:14px;margin:14px 0 8px;color:var(--text-dim);text-transform:uppercase;letter-spacing:1px">${label}</h3>` +
      `<table class="data"><tbody>` + arr.map((it) =>
        `<tr><td><a href="${base}/dataset/${it.slug}">${it.title}</a></td>` +
        `<td class="num">${fmt(it.value, it.unit)}</td>` +
        `<td class="num" style="color:var(--text-dim)">#${it.rank}/${it.total}</td></tr>`).join('') + `</tbody></table>` : '';
    itemsEl.innerHTML = block('Macro', groups.macro) + block('Study', groups.survey);
  }

  function highlight(c) {
    const num = numByIso[c.iso];
    mapEl.querySelectorAll('.country').forEach((p) => {
      const on = p.getAttribute('data-num') === num;
      p.setAttribute('fill', on ? 'var(--accent)' : 'var(--bg-elev)');
      p.style.opacity = on ? '1' : '0.4';
    });
  }

  let wikiSeq = 0;
  async function loadWiki(name) {
    const seq = ++wikiSeq;
    extractEl.textContent = '';
    const title = WIKI[name] || name;
    try {
      const r = await fetch(`https://en.wikipedia.org/api/rest_v1/page/summary/${encodeURIComponent(title)}?redirect=true`);
      if (!r.ok) return;
      const j = await r.json();
      if (seq === wikiSeq && j.extract && j.type !== 'disambiguation') extractEl.textContent = j.extract;
    } catch {}
  }

  function syncUrl() {
    const p = new URLSearchParams(location.search);
    p.set('c', sel.value);
    history.replaceState(null, '', location.pathname + '?' + p.toString() + location.hash);
  }

  function render() {
    const c = countries.find((x) => x.iso === sel.value);
    if (!c) return;
    nameEl.textContent = c.name;
    descEl.textContent = describe(c);
    renderItems(c);
    highlight(c);
    loadWiki(c.name);
  }

  fetch(`${base}/data/country-index.json`).then((r) => r.json()).then((data) => {
    countries = data;
    sel.innerHTML = data.map((c) => `<option value="${c.iso}">${c.name}</option>`).join('');
    const want = new URLSearchParams(location.search).get('c');
    const def = data.find((c) => c.iso === want) || data.find((c) => c.iso === 'FIN') || data[0];
    if (def) sel.value = def.iso;
    render();
  });
  sel.addEventListener('change', () => { render(); syncUrl(); });
</script>
