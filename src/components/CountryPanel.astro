---
import WorldMap from '@components/WorldMap.astro';
import isoNumeric from '@data/iso-numeric.json';
import isoAlpha2 from '@data/iso-alpha2.json';
import countryMeta from '@data/country-meta.json';
import { TOPICS, TOPIC_ORDER } from '@lib/topics';
import { feature } from 'topojson-client';
import { geoNaturalEarth1 } from 'd3-geo';
import { readFileSync } from 'node:fs';
import { createRequire } from 'node:module';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Recreate WorldMap's projection so the client can place a capital marker in
// the same SVG coordinate space (Natural Earth 1, fit to 960×480).
const require = createRequire(import.meta.url);
const topo = JSON.parse(readFileSync(require.resolve('world-atlas/countries-110m.json'), 'utf8'));
const fc: any = feature(topo, (topo as any).objects.countries);
const proj = geoNaturalEarth1().fitSize([960, 480], fc);
const projParams = { scale: proj.scale(), tx: proj.translate()[0], ty: proj.translate()[1] };
const topicMeta = TOPIC_ORDER.map((id) => ({ id, label: TOPICS[id].label, icon: TOPICS[id].icon }));
---
<div class="country-panel">
  <div class="controls">
    <label>Country<select id="country-sel"><option>Loading…</option></select></label>
  </div>

  <div class="country-card">
    <div class="cc-info">
      <img id="cc-coa" class="cc-coa" alt="" hidden />
      <h3 id="cc-name">—</h3>
      <p class="cc-extract" id="cc-extract"></p>
      <p class="country-desc" id="country-desc"></p>
    </div>
    <div class="cc-map" id="country-map"><WorldMap legendId="country-legend" showLegend={false} /></div>
  </div>

  <div class="ci-controls">
    <input id="ci-search" type="search" placeholder="Filter indicators…" autocomplete="off" />
    <select id="ci-sort">
      <option value="topic">Group by topic</option>
      <option value="rank">Sort by rank (best first)</option>
      <option value="rankw">Sort by rank (worst first)</option>
    </select>
    <select id="ci-topic"><option value="">All topics</option></select>
  </div>
  <div id="country-items" style="margin-top:8px"></div>
</div>

<script type="application/json" id="cp-iso" set:html={JSON.stringify(isoNumeric)}></script>
<script type="application/json" id="cp-a2" set:html={JSON.stringify(isoAlpha2)}></script>
<script type="application/json" id="cp-meta" set:html={JSON.stringify(countryMeta)}></script>
<script define:vars={{ base, projParams, topicMeta }}>
  const isoNumeric = JSON.parse(document.getElementById('cp-iso').textContent);
  const isoAlpha2 = JSON.parse(document.getElementById('cp-a2').textContent);
  const META = JSON.parse(document.getElementById('cp-meta').textContent);
  const flag = (iso) => { const a2 = iso && isoAlpha2[iso.toUpperCase()]; return a2 ? String.fromCodePoint(...[...a2].map((c) => 0x1f1e6 + c.charCodeAt(0) - 65)) + ' ' : ''; };
  const numByIso = Object.fromEntries(Object.entries(isoNumeric).map(([n, a]) => [a, n]));
  const sel = document.getElementById('country-sel');
  const descEl = document.getElementById('country-desc');
  const itemsEl = document.getElementById('country-items');
  const mapEl = document.getElementById('country-map');
  const nameEl = document.getElementById('cc-name');
  const extractEl = document.getElementById('cc-extract');
  const coaEl = document.getElementById('cc-coa');
  const ciSearch = document.getElementById('ci-search');
  const ciSort = document.getElementById('ci-sort');
  const ciTopic = document.getElementById('ci-topic');
  const TICON = Object.fromEntries(topicMeta.map((t) => [t.id, t.icon]));
  const TLABEL = Object.fromEntries(topicMeta.map((t) => [t.id, t.label]));
  const TORDER = topicMeta.map((t) => t.id);
  const ciState = { q: '', sort: 'topic', topic: '' };
  let currentC = null;
  let countries = [];

  // Project lon/lat → SVG coords with the same Natural Earth 1 fit as WorldMap.
  function proj(lon, lat) {
    const l = lon * Math.PI / 180, p = lat * Math.PI / 180, p2 = p * p, p4 = p2 * p2;
    const x = l * (0.8707 - 0.131979 * p2 + p4 * (-0.013791 + p4 * (0.003971 * p2 - 0.001529 * p4)));
    const y = p * (1.007226 + p2 * (0.015085 + p4 * (-0.044475 + 0.028874 * p2 - 0.005916 * p4)));
    return [projParams.tx + projParams.scale * x, projParams.ty - projParams.scale * y];
  }
  const SVGNS = 'http://www.w3.org/2000/svg';
  let marker = null;
  function ensureMarker(svg) {
    if (marker && marker.isConnected) return marker;
    marker = document.createElementNS(SVGNS, 'g'); marker.id = 'cc-marker';
    const halo = document.createElementNS(SVGNS, 'circle'); halo.setAttribute('class', 'cc-cap-halo');
    const dot = document.createElementNS(SVGNS, 'circle'); dot.setAttribute('class', 'cc-cap-dot');
    const txt = document.createElementNS(SVGNS, 'text'); txt.setAttribute('class', 'cc-cap-label'); txt.setAttribute('text-anchor', 'middle');
    marker.append(halo, dot, txt); svg.appendChild(marker);
    return marker;
  }

  // Zoom the map to the selected country (silhouette + a margin of neighbours)
  // and drop a labelled dot on its capital.
  function focusMap(c) {
    const svg = mapEl.querySelector('svg'); if (!svg) return;
    const num = numByIso[c.iso];
    const path = mapEl.querySelector(`.country[data-num="${num}"]`);
    if (!path) return;
    const bb = path.getBBox();
    if (!bb.width) { requestAnimationFrame(() => focusMap(c)); return; } // not laid out yet
    const padX = Math.max(bb.width * 0.65, 22), padY = Math.max(bb.height * 0.65, 22);
    let x = bb.x - padX, y = bb.y - padY, w = bb.width + 2 * padX, h = bb.height + 2 * padY;
    const aspect = 960 / 480;                       // keep the container's shape
    if (w / h < aspect) { const nw = h * aspect; x -= (nw - w) / 2; w = nw; }
    else { const nh = w / aspect; y -= (nh - h) / 2; h = nh; }
    x = Math.max(0, Math.min(x, 960 - w)); y = Math.max(0, Math.min(y, 480 - h));
    svg.setAttribute('viewBox', `${x} ${y} ${w} ${h}`);
    const m = ensureMarker(svg), meta = META[c.iso];
    if (meta && meta.lat !== undefined) {
      const [cx, cy] = proj(meta.lon, meta.lat);
      const r = Math.max(1.5, w * 0.007), fs = Math.max(5, w * 0.02);
      m.style.display = ''; m.setAttribute('transform', `translate(${cx} ${cy})`);
      m.querySelector('.cc-cap-halo').setAttribute('r', r * 2);
      m.querySelector('.cc-cap-dot').setAttribute('r', r);
      const t = m.querySelector('.cc-cap-label'); t.textContent = meta.capital || ''; t.setAttribute('font-size', fs); t.setAttribute('dy', -r * 2 - 2);
    } else { m.style.display = 'none'; }
  }

  function coatOfArms(c) {
    const meta = META[c.iso];
    if (meta && meta.coa) { coaEl.src = meta.coa + '?width=120'; coaEl.alt = `${c.name} coat of arms`; coaEl.hidden = false; }
    else { coaEl.hidden = true; coaEl.removeAttribute('src'); }
  }

  const fmt = (v, unit) => `${v.toLocaleString('en-US', { maximumFractionDigits: 1 })}${unit && unit.includes('%') ? '%' : ''}`;
  const find = (c, slug) => c.items.find((i) => i.slug === slug);

  // Wikipedia title aliases for names that differ from our datasets.
  const WIKI = { 'Russian Federation': 'Russia', 'Korea, Rep.': 'South Korea', 'Iran, Islamic Rep.': 'Iran', 'Egypt, Arab Rep.': 'Egypt', 'Venezuela, RB': 'Venezuela', 'Viet Nam': 'Vietnam', 'Türkiye, Republic of': 'Turkey', 'Czechia': 'Czech Republic', 'Slovak Republic': 'Slovakia', 'Lao PDR': 'Laos', 'Syrian Arab Republic': 'Syria' };

  function describe(c) {
    const bits = [];
    const gdp = find(c, 'imf-gdp-per-capita-ppp') || find(c, 'imf-gdp-per-capita');
    const life = find(c, 'gapminder-life-expectancy');
    const happy = find(c, 'whr-happiness');
    const dem = find(c, 'v-dem-v2x-libdem');
    if (gdp) bits.push(`GDP per capita ${Math.round(gdp.value).toLocaleString()} ${gdp.unit} (#${gdp.rank})`);
    if (life) bits.push(`life expectancy ${life.value} yrs`);
    if (happy) bits.push(`happiness ${happy.value} (#${happy.rank})`);
    if (dem) bits.push(`liberal-democracy ${dem.value} (#${dem.rank})`);
    return `${c.region || 'World'}. ${bits.join(' · ')}.`;
  }

  const row = (it) => `<tr><td><span class="ind-ic">${TICON[it.topic] || ''}</span><a href="${base}/dataset/${it.slug}">${it.title}</a></td>` +
    `<td class="num">${fmt(it.value, it.unit)}</td>` +
    `<td class="num" style="color:var(--text-dim)">#${it.rank}/${it.total}</td></tr>`;

  function renderItems(c) {
    currentC = c;
    // keep the topic filter in sync with the topics this country actually has
    const present = TORDER.filter((id) => c.items.some((it) => it.topic === id));
    if (ciTopic.dataset.iso !== c.iso) {
      ciTopic.dataset.iso = c.iso;
      ciTopic.innerHTML = '<option value="">All topics</option>' +
        present.map((id) => `<option value="${id}">${TICON[id]} ${TLABEL[id]}</option>`).join('');
      if (![...ciTopic.options].some((o) => o.value === ciState.topic)) ciState.topic = '';
      ciTopic.value = ciState.topic;
    }
    const q = ciState.q.toLowerCase();
    let items = c.items.filter((it) => (!q || it.title.toLowerCase().includes(q)) && (!ciState.topic || it.topic === ciState.topic));
    if (!items.length) { itemsEl.innerHTML = '<p class="sub">No indicators match.</p>'; return; }

    if (ciState.sort === 'rank' || ciState.sort === 'rankw') {
      const dir = ciState.sort === 'rank' ? 1 : -1;        // rank percentile, best first
      items = [...items].sort((a, b) => dir * (a.rank / a.total - b.rank / b.total));
      itemsEl.innerHTML = `<table class="data"><tbody>${items.map(row).join('')}</tbody></table>`;
      return;
    }
    // group by topic
    const block = (id) => {
      const arr = items.filter((it) => it.topic === id).sort((a, b) => a.title.localeCompare(b.title));
      return arr.length ? `<h3 style="font-size:13px;margin:14px 0 6px;color:var(--text-dim);text-transform:uppercase;letter-spacing:1px">${TICON[id]} ${TLABEL[id]}</h3>` +
        `<table class="data"><tbody>${arr.map(row).join('')}</tbody></table>` : '';
    };
    itemsEl.innerHTML = TORDER.map(block).join('');
  }

  function highlight(c) {
    const num = numByIso[c.iso];
    mapEl.querySelectorAll('.country').forEach((p) => {
      const on = p.getAttribute('data-num') === num;
      p.setAttribute('fill', on ? 'var(--accent)' : 'var(--bg-elev)');
      p.style.opacity = on ? '1' : '0.4';
    });
  }

  let wikiSeq = 0;
  async function loadWiki(name) {
    const seq = ++wikiSeq;
    extractEl.textContent = '';
    const title = WIKI[name] || name;
    try {
      const r = await fetch(`https://en.wikipedia.org/api/rest_v1/page/summary/${encodeURIComponent(title)}?redirect=true`);
      if (!r.ok) return;
      const j = await r.json();
      if (seq === wikiSeq && j.extract && j.type !== 'disambiguation') extractEl.textContent = j.extract;
    } catch {}
  }

  function syncUrl() {
    const p = new URLSearchParams(location.search);
    p.set('c', sel.value);
    history.replaceState(null, '', location.pathname + '?' + p.toString() + location.hash);
  }

  function render() {
    const c = countries.find((x) => x.iso === sel.value);
    if (!c) return;
    nameEl.textContent = flag(c.iso) + c.name;
    descEl.textContent = describe(c);
    renderItems(c);
    highlight(c);
    focusMap(c);
    coatOfArms(c);
    loadWiki(c.name);
  }

  fetch(`${base}/data/country-index.json`).then((r) => r.json()).then((data) => {
    countries = data;
    sel.innerHTML = data.map((c) => `<option value="${c.iso}">${flag(c.iso)}${c.name}</option>`).join('');
    const want = new URLSearchParams(location.search).get('c');
    const def = data.find((c) => c.iso === want) || data.find((c) => c.iso === 'FIN') || data[0];
    if (def) sel.value = def.iso;
    render();
  });
  sel.addEventListener('change', () => { render(); syncUrl(); });
  ciSearch.addEventListener('input', () => { ciState.q = ciSearch.value.trim(); if (currentC) renderItems(currentC); });
  ciSort.addEventListener('change', () => { ciState.sort = ciSort.value; if (currentC) renderItems(currentC); });
  ciTopic.addEventListener('change', () => { ciState.topic = ciTopic.value; if (currentC) renderItems(currentC); });
</script>
