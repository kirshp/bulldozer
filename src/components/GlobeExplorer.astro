---
/**
 * Interactive 3D globe for /macro: drag to spin, click a country for its key
 * indicators. Countries are shaded by a composite score (mean oriented
 * percentile across 8 headline datasets) or by any single indicator.
 * Data: src/data/globe-indicators.json (scripts/gen_globe_data.mjs).
 * Runtime: d3-geo + topojson-client from public/vendor, topology fetched
 * from public/data — nothing new in the page bundle.
 */
import globeData from '@data/globe-indicators.json';
import isoNumeric from '@data/iso-numeric.json';
import countryMeta from '@data/country-meta.json';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const scored = Object.values(globeData.countries as Record<string, any>).filter((c: any) => c.score != null).length;
// Trimmed capital lookup for the globe: iso3 → [name, lon, lat]. Drops the
// coat-of-arms URLs so we ship only what the label layer needs.
const capitals: Record<string, [string, number, number]> = {};
for (const [iso, m] of Object.entries(countryMeta as Record<string, any>)) {
  if (m && m.capital && m.lon != null && m.lat != null) capitals[iso] = [m.capital, m.lon, m.lat];
}
---
<div class="globe-x">
  <div id="gx-views" class="gx-views" role="tablist" aria-label="Map style">
    <button type="button" class="gx-vbtn active" data-v="globe" role="tab" aria-selected="true">🌐 Globe</button>
    <button type="button" class="gx-vbtn" data-v="flat" role="tab" aria-selected="false">🗺️ Flat map</button>
  </div>
  <div id="gx-metrics" class="fchips" role="tablist" aria-label="Colour the map by"></div>
  <div class="gx-grid">
    <div class="gx-stage">
      <canvas id="gx-globe" aria-label="Interactive globe: drag to rotate, click a country for details"></canvas>
      <div class="gx-zoom">
        <button id="gx-zin" type="button" aria-label="Zoom in">+</button>
        <button id="gx-zout" type="button" aria-label="Zoom out">−</button>
        <button id="gx-zreset" type="button" aria-label="Reset view">⟳</button>
      </div>
      <div id="gx-legend" class="gx-legend"></div>
    </div>
    <div id="gx-panel" class="gx-panel"></div>
  </div>
</div>

<script type="application/json" id="gx-data" set:html={JSON.stringify(globeData)}></script>
<script type="application/json" id="gx-isonum" set:html={JSON.stringify(isoNumeric)}></script>
<script type="application/json" id="gx-capitals" set:html={JSON.stringify(capitals)}></script>
<script is:inline src={`${base}/vendor/d3-array.min.js`}></script>
<script is:inline src={`${base}/vendor/d3-geo.min.js`}></script>
<script is:inline src={`${base}/vendor/topojson-client.min.js`}></script>
<script is:inline data-base={base}>
(async () => {
  const base = document.currentScript.dataset.base;
  const DATA = JSON.parse(document.getElementById('gx-data').textContent);
  const ISO_NUM = JSON.parse(document.getElementById('gx-isonum').textContent);
  const CAP = JSON.parse(document.getElementById('gx-capitals').textContent);
  const META = DATA.meta, C = DATA.countries;
  let topo;
  try { topo = await (await fetch(base + '/data/world-110m.json')).json(); }
  catch (e) { document.querySelector('.globe-x').style.display = 'none'; return; }

  const world = topojson.feature(topo, topo.objects.countries).features;
  for (const f of world) { f.iso = ISO_NUM[String(Number(f.id))] || null; f.c = d3.geoCentroid(f); f.area = d3.geoArea(f); }
  const byIso = new Map(world.filter((f) => f.iso).map((f) => [f.iso, f]));

  const SHORT = { 'Taiwan Province of China': 'Taiwan', 'Russian Federation': 'Russia', 'Slovak Republic': 'Slovakia',
    'Kyrgyz Republic': 'Kyrgyzstan', 'Lao P.D.R.': 'Laos', 'Brunei Darussalam': 'Brunei', 'Syrian Arab Republic': 'Syria',
    'Islamic Republic of Iran': 'Iran', 'Democratic Republic of the Congo': 'DR Congo', 'Republic of Congo': 'Congo',
    'The Gambia': 'Gambia', 'Republic of Korea': 'South Korea', 'United Arab Emirates': 'UAE',
    'Bosnia and Herzegovina': 'Bosnia & Herz.' };
  for (const iso in C) if (SHORT[C[iso].n]) C[iso].n = SHORT[C[iso].n];

  const METRIC_KEYS = ['score', 'whr-happiness', 'gdp-pc', 'life', 'cpi', 'libdem', 'internet', 'inflation', 'growth'];
  const MLABEL = (k) => (k === 'score' ? 'Overall score' : META[k].label);
  const PAL = ['#23a29b', '#6fb887', '#d9bd6c', '#e08d64', '#d65a6b'];
  const NODATA_L = '#c6c8d6', NODATA_D = '#3a3e46';

  // theme-dependent canvas colours (site toggles html[data-theme])
  const THEMES = {
    dark: { sphere: ['#262a36', '#1a1c25', '#121318'], halo: 'rgba(255,176,0,0.10)', rim: 'rgba(255,255,255,0.14)',
      border: 'rgba(10,11,14,0.9)', chipBg: 'rgba(28,31,35,0.95)', chipText: '#e7e9ec', tint: 0.34, nodata: NODATA_D },
    light: { sphere: ['#ffffff', '#efecf8', '#dcd8ee'], halo: 'rgba(192,127,0,0.12)', rim: 'rgba(120,115,140,0.3)',
      border: 'rgba(255,255,255,0.8)', chipBg: 'rgba(255,255,255,0.95)', chipText: '#3a3950', tint: 0.28, nodata: NODATA_L },
  };
  const themeName = () => (document.documentElement.getAttribute('data-theme') === 'light' ? 'light' : 'dark');
  let TH = THEMES[themeName()];
  new MutationObserver(() => { TH = THEMES[themeName()]; patterns = {}; dirty = true; })
    .observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

  const pctOf = (iso, k) => { const c = C[iso]; if (!c) return null; if (k === 'score') return c.score ?? null; const v = c.v[k]; return v ? v[2] : null; };
  const valOf = (iso, k) => { const c = C[iso]; if (!c) return null; if (k === 'score') return c.score ?? null; const v = c.v[k]; return v ? v[0] : null; };
  const tierColor = (p) => (p == null ? TH.nodata : p >= 80 ? PAL[0] : p >= 60 ? PAL[1] : p >= 40 ? PAL[2] : p >= 20 ? PAL[3] : PAL[4]);
  const tierName = (p) => (p >= 80 ? 'Thriving' : p >= 60 ? 'Solid' : p >= 40 ? 'Mixed' : p >= 20 ? 'Strained' : 'Critical');
  const flag = (a2) => (a2 ? String.fromCodePoint(...[...a2.toUpperCase()].map((c) => 0x1f1e6 + c.charCodeAt(0) - 65)) : '🏳️');
  function fmt(k, v) {
    if (v == null) return '—';
    const f = k === 'score' ? 'd0' : META[k].fmt;
    if (f === 'usd') return v >= 1000 ? '$' + Math.round(v / 1000).toLocaleString() + 'k' : '$' + Math.round(v);
    if (f === 'pop') return v >= 1000 ? (v / 1000).toFixed(2) + 'B' : v >= 1 ? (+v).toFixed(1) + 'M' : Math.round(v * 1000) + 'k';
    if (f === 'd2') return (+v).toFixed(2);
    if (f === 'd1') return (+v).toFixed(1);
    return String(Math.round(v));
  }
  const hexA = (hex, a) => { const n = parseInt(hex.slice(1), 16); return 'rgba(' + (n >> 16) + ',' + ((n >> 8) & 255) + ',' + (n & 255) + ',' + a + ')'; };

  const canvas = document.getElementById('gx-globe');
  const ctx = canvas.getContext('2d');
  const stage = canvas.parentElement;
  let size = 560;
  function resize() {
    const w = stage.getBoundingClientRect().width;
    size = Math.max(300, Math.min(w, 620));
    const dpr = window.devicePixelRatio || 1;
    canvas.width = size * dpr; canvas.height = size * dpr;
    canvas.style.width = size + 'px'; canvas.style.height = size + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    dirty = true;
  }
  window.addEventListener('resize', resize);

  const projGlobe = d3.geoOrthographic().clipAngle(90);
  const projFlat = d3.geoNaturalEarth1();
  let view = 'globe';
  let projection = projGlobe;
  let path = d3.geoPath(projection, ctx);
  let rot = [58, -14], zoom = 1, pan = [0, 0], dirty = true;
  let metric = 'score', selected = null, chipRects = [];
  let vel = [0, 0], dragging = false, lastPtr = null, movedDist = 0, lastInteract = performance.now();
  let tween = null, patterns = {};

  function pat(color) {
    if (patterns[color]) return patterns[color];
    const c = document.createElement('canvas'); c.width = c.height = 6;
    const x = c.getContext('2d');
    x.fillStyle = color; x.globalAlpha = 0.95;
    x.beginPath(); x.arc(3, 3, 1.7, 0, 7); x.fill();
    return (patterns[color] = ctx.createPattern(c, 'repeat'));
  }
  function topCountries(n) {
    return Object.entries(C)
      .map(([iso, c]) => ({ iso, c, p: pctOf(iso, metric), v: valOf(iso, metric) }))
      .filter((r) => r.p != null && byIso.has(r.iso))
      .sort((a, b) => b.p - a.p || b.v - a.v).slice(0, n);
  }

  function render() {
    const R = size / 2;
    if (view === 'globe') {
      projection = projGlobe;
      projection.translate([R, R]).scale((R - 14) * zoom).rotate([rot[0], rot[1]]);
    } else {
      projection = projFlat;
      projection.fitExtent([[6, 6], [size - 6, size - 6]], { type: 'Sphere' });
      projection.scale(projection.scale() * zoom);
      const t = projection.translate();
      projection.translate([t[0] + pan[0], t[1] + pan[1]]);
    }
    path = d3.geoPath(projection, ctx);
    ctx.clearRect(0, 0, size, size);
    if (view === 'globe') {
      let g = ctx.createRadialGradient(R, R, (R - 14) * zoom * 0.92, R, R, (R - 14) * zoom * 1.13);
      g.addColorStop(0, TH.halo); g.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.fillStyle = g; ctx.fillRect(0, 0, size, size);
      ctx.beginPath(); path({ type: 'Sphere' });
      g = ctx.createRadialGradient(R - R * 0.35, R - R * 0.42, R * 0.1, R, R, (R - 14) * zoom * 1.02);
      g.addColorStop(0, TH.sphere[0]); g.addColorStop(0.55, TH.sphere[1]); g.addColorStop(1, TH.sphere[2]);
      ctx.fillStyle = g; ctx.fill();
    } else {
      ctx.beginPath(); path({ type: 'Sphere' });
      ctx.fillStyle = TH.sphere[1]; ctx.fill();
    }
    for (const f of world) {
      const p = f.iso ? pctOf(f.iso, metric) : null;
      const col = tierColor(p);
      ctx.beginPath(); path(f);
      ctx.fillStyle = hexA(col, p == null ? 0.14 : TH.tint); ctx.fill();
      ctx.fillStyle = pat(col); ctx.fill();
      ctx.strokeStyle = TH.border; ctx.lineWidth = 0.6; ctx.stroke();
    }
    if (selected && byIso.has(selected)) {
      const f = byIso.get(selected);
      const col = tierColor(pctOf(selected, metric));
      ctx.beginPath(); path(f);
      ctx.fillStyle = hexA(col, 0.55); ctx.fill();
      ctx.fillStyle = pat(col); ctx.fill();
      ctx.strokeStyle = TH.chipText; ctx.lineWidth = 1.6; ctx.stroke();
    }
    ctx.beginPath(); path({ type: 'Sphere' });
    ctx.strokeStyle = TH.rim; ctx.lineWidth = 1.2; ctx.stroke();

    // ---- label layer: prominent country names + their capitals ----
    chipRects = [];
    const center = [-rot[0], -rot[1]];
    const placed = [];  // shared collision boxes {cx,cy,w,h} across names + capitals
    const fits = (cx, cy, w, h) => !placed.some((r) => Math.abs(cx - r.cx) < (w + r.w) / 2 + 3 && Math.abs(cy - r.cy) < (h + r.h) / 2 + 3);

    // pick the labelled countries: the largest ones on the near side, plus the selection
    const facing = world
      .filter((f) => f.iso && C[f.iso] && (view !== 'globe' || d3.geoDistance(f.c, center) < 1.28))
      .sort((a, b) => b.area - a.area)
      .slice(0, view === 'globe' ? 16 : 22);
    if (selected && byIso.has(selected) && !facing.some((f) => f.iso === selected)) facing.push(byIso.get(selected));

    // country-name pills — priority in the collision layer
    ctx.font = '700 11.5px system-ui, -apple-system, "Segoe UI", Roboto, sans-serif';
    ctx.textBaseline = 'middle';
    for (const f of facing) {
      const iso = f.iso;
      const [x, y] = projection(f.c);
      const name = (C[iso] && C[iso].n) || f.properties.name;
      const sel = iso === selected;
      const w = ctx.measureText(name).width + 18, h = 21;
      if (!fits(x, y, w, h)) continue;
      placed.push({ cx: x, cy: y, w, h });
      const col = tierColor(pctOf(iso, metric));
      ctx.beginPath(); ctx.roundRect(x - w / 2, y - h / 2, w, h, 10);
      ctx.fillStyle = sel ? col : TH.chipBg;
      ctx.shadowColor = 'rgba(0,0,0,0.3)'; ctx.shadowBlur = 6; ctx.shadowOffsetY = 2;
      ctx.fill(); ctx.shadowBlur = 0; ctx.shadowOffsetY = 0;
      ctx.strokeStyle = sel ? col : hexA(col, 0.85); ctx.lineWidth = 1.4; ctx.stroke();
      ctx.fillStyle = sel ? '#fff' : TH.chipText;
      ctx.textAlign = 'center';
      ctx.fillText(name, x, y + 0.5);
      chipRects.push({ x: x - w / 2, y: y - h / 2, w, h, iso });
    }

    // capitals — a gold dot on the near side, with a name where it fits
    ctx.font = '600 10px system-ui, -apple-system, "Segoe UI", Roboto, sans-serif';
    for (const f of facing) {
      const cap = CAP[f.iso]; if (!cap) continue;
      const cll = [cap[1], cap[2]];
      if (view === 'globe' && d3.geoDistance(cll, center) > 1.45) continue;
      const [cx, cy] = projection(cll);
      ctx.beginPath(); ctx.arc(cx, cy, 3.1, 0, 7);
      ctx.fillStyle = '#ffb100'; ctx.fill();
      ctx.lineWidth = 1.3; ctx.strokeStyle = 'rgba(35,22,0,0.85)'; ctx.stroke();
      const label = cap[0];
      const lw = ctx.measureText(label).width, lh = 13;
      const lx = cx + 8 + lw / 2, ly = cy;
      if (!fits(lx, ly, lw + 4, lh)) continue;
      placed.push({ cx: lx, cy: ly, w: lw + 4, h: lh });
      ctx.textAlign = 'left';
      ctx.lineJoin = 'round'; ctx.lineWidth = 3; ctx.strokeStyle = TH.chipBg;
      ctx.strokeText(label, cx + 8, cy);
      ctx.fillStyle = TH.chipText; ctx.fillText(label, cx + 8, cy);
    }
  }

  const sens = () => 0.28 / zoom;
  canvas.addEventListener('pointerdown', (e) => {
    dragging = true; movedDist = 0; lastPtr = [e.clientX, e.clientY]; vel = [0, 0];
    canvas.setPointerCapture(e.pointerId); lastInteract = performance.now(); tween = null;
  });
  canvas.addEventListener('pointermove', (e) => {
    if (!dragging) return;
    const dx = e.clientX - lastPtr[0], dy = e.clientY - lastPtr[1];
    lastPtr = [e.clientX, e.clientY]; movedDist += Math.abs(dx) + Math.abs(dy);
    if (view === 'globe') {
      rot[0] += dx * sens(); rot[1] = Math.max(-78, Math.min(78, rot[1] - dy * sens()));
      vel = [dx * sens(), dy * sens()];
    } else {
      pan[0] += dx; pan[1] += dy;
    }
    lastInteract = performance.now(); dirty = true;
  });
  canvas.addEventListener('pointerup', (e) => {
    dragging = false; lastInteract = performance.now();
    if (movedDist < 5) handleClick(e);
  });
  canvas.addEventListener('wheel', (e) => {
    e.preventDefault();
    zoom = Math.max(0.7, Math.min(2.4, zoom * Math.pow(1.0015, -e.deltaY)));
    lastInteract = performance.now(); dirty = true;
  }, { passive: false });

  function handleClick(e) {
    const r = canvas.getBoundingClientRect();
    const x = e.clientX - r.left, y = e.clientY - r.top;
    for (const c of chipRects) if (x >= c.x && x <= c.x + c.w && y >= c.y && y <= c.y + c.h) return select(c.iso);
    const ll = projection.invert([x, y]);
    if (!ll || isNaN(ll[0])) return;
    if (view === 'globe' && d3.geoDistance(ll, [-rot[0], -rot[1]]) > Math.PI / 2) return;
    for (const f of world) if (d3.geoContains(f, ll)) return select(f.iso);
    select(null);
  }

  const chipsEl = document.getElementById('gx-metrics');
  chipsEl.innerHTML = METRIC_KEYS.map((k, i) => '<button type="button" class="fchip' + (i === 0 ? ' active' : '') + '" data-k="' + k + '">' + MLABEL(k) + '</button>').join('');
  chipsEl.addEventListener('click', (e) => {
    const b = e.target.closest('.fchip'); if (!b) return;
    metric = b.dataset.k;
    [...chipsEl.children].forEach((c) => c.classList.toggle('active', c === b));
    renderPanel(); dirty = true;
  });

  const panelEl = document.getElementById('gx-panel');
  function renderPanel() {
    if (!selected || !C[selected]) {
      const best = topCountries(3);
      panelEl.innerHTML = '<div class="gx-ph">' +
        '<p><b>Drag to spin · click a country</b> for its key indicators, or tap a code chip.</p>' +
        '<p class="gx-dim">Coloured by ' + MLABEL(metric).toLowerCase() + ' — leaders right now: ' +
        best.map((r) => flag(r.c.a2) + ' ' + r.c.n).join(', ') + '.</p>' +
        '<p class="gx-dim">' + Object.values(C).filter((c) => c.score != null).length +
        ' countries scored across 8 open datasets — WHR, IMF WEO, Gapminder, Transparency International, V-Dem.</p></div>';
      return;
    }
    const c = C[selected];
    const s = c.score;
    const rows = METRIC_KEYS.filter((k) => k !== 'score').concat('pop').map((k) => {
      const v = c.v[k];
      const p = v ? v[2] : null;
      return '<div class="gx-row"><span class="gl">' + META[k].label + '</span>' +
        '<span class="gb">' + (p != null ? '<i style="width:' + p + '%;background:' + tierColor(p) + '"></i>' : '') + '</span>' +
        '<span class="gv">' + (v ? fmt(k, v[0]) : '—') + '<em>' + META[k].unit + '</em></span>' +
        '<span class="gr">' + (v ? '#' + v[1] + '<em>/' + META[k].n + '</em>' : '') + '</span></div>';
    }).join('');
    panelEl.innerHTML =
      '<div class="gx-head"><span class="gx-flag">' + flag(c.a2) + '</span><div><h3>' + c.n + '</h3>' +
      '<span class="gx-dim">' + selected + ' · rank among countries with data</span></div></div>' +
      (s != null
        ? '<div class="gx-score"><span class="gx-big">' + s + '<em>/100</em></span>' +
          '<span class="gx-pill" style="background:' + hexA(tierColor(s), 0.16) + ';color:' + tierColor(s) + '">' + tierName(s) + '</span></div>' +
          '<p class="gx-dim" style="margin:2px 0 8px">BullDozer composite — mean percentile across 8 indicators</p>'
        : '<p class="gx-dim" style="margin:10px 0">Not enough data for a composite score.</p>') +
      '<div class="gx-rows">' + rows + '</div>' +
      '<p class="gx-dim" style="margin-top:10px">Latest year per dataset · every number sourced.</p>';
  }
  function select(iso) { selected = iso; renderPanel(); dirty = true; }

  document.getElementById('gx-zin').addEventListener('click', () => { zoom = Math.min(2.4, zoom * 1.25); dirty = true; lastInteract = performance.now(); });
  document.getElementById('gx-zout').addEventListener('click', () => { zoom = Math.max(0.7, zoom / 1.25); dirty = true; lastInteract = performance.now(); });
  document.getElementById('gx-zreset').addEventListener('click', () => { zoom = 1; rot = [58, -14]; pan = [0, 0]; select(null); lastInteract = performance.now(); dirty = true; });

  const viewsEl = document.getElementById('gx-views');
  viewsEl.addEventListener('click', (e) => {
    const b = e.target.closest('.gx-vbtn'); if (!b || b.dataset.v === view) return;
    view = b.dataset.v;
    [...viewsEl.children].forEach((c) => { const on = c === b; c.classList.toggle('active', on); c.setAttribute('aria-selected', on); });
    zoom = 1; pan = [0, 0]; vel = [0, 0]; lastInteract = performance.now(); dirty = true;
  });

  document.getElementById('gx-legend').innerHTML =
    [['Thriving', PAL[0]], ['Solid', PAL[1]], ['Mixed', PAL[2]], ['Strained', PAL[3]], ['Critical', PAL[4]]]
      .map(([n, c]) => '<span class="lg"><i style="background:' + c + '"></i>' + n + '</span>').join('') +
    '<span class="lg lg-nd"><i></i>No data</span>';

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  function frame() {
    if (tween) tween();
    if (view === 'globe' && !dragging && (Math.abs(vel[0]) > 0.02 || Math.abs(vel[1]) > 0.02)) {
      rot[0] += vel[0]; rot[1] = Math.max(-78, Math.min(78, rot[1] - vel[1]));
      vel = [vel[0] * 0.94, vel[1] * 0.94];
      dirty = true;
    }
    if (view === 'globe' && !reduceMotion && !dragging && !tween && performance.now() - lastInteract > 4000) { rot[0] += 0.04; dirty = true; }
    if (dirty) { render(); dirty = false; }
    requestAnimationFrame(frame);
  }
  resize(); renderPanel(); frame();
  setTimeout(resize, 60);
})();
</script>

<style>
  .globe-x { margin: 10px 0 26px; }
  .globe-x .gx-views { display: inline-flex; gap: 2px; padding: 3px; margin-bottom: 12px;
    background: var(--bg-elev); border: 1px solid var(--border); border-radius: 999px; }
  .globe-x .gx-vbtn { border: 0; background: transparent; color: var(--text-dim);
    font: 600 13px var(--font); padding: 6px 16px; border-radius: 999px; cursor: pointer; transition: background .15s, color .15s; }
  .globe-x .gx-vbtn:hover { color: var(--text); }
  .globe-x .gx-vbtn.active { background: var(--accent); color: #1a1300; }
  .globe-x .fchips { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 10px; }
  .gx-grid { display: grid; grid-template-columns: minmax(300px, 620px) minmax(280px, 1fr); gap: 22px; align-items: start; }
  .gx-stage { position: relative; display: flex; justify-content: center; }
  #gx-globe { cursor: grab; touch-action: none; max-width: 100%; }
  #gx-globe:active { cursor: grabbing; }
  .gx-zoom { position: absolute; right: 6px; top: 10px; display: flex; flex-direction: column; gap: 6px; }
  .gx-zoom button { width: 34px; height: 34px; border-radius: 50%; border: 1px solid var(--border); background: var(--bg-card);
    color: var(--text-dim); font-size: 15px; cursor: pointer; }
  .gx-zoom button:hover { color: var(--accent); border-color: var(--accent); }
  .gx-legend { position: absolute; left: 50%; transform: translateX(-50%); bottom: 2px; display: flex; gap: 10px; flex-wrap: wrap;
    justify-content: center; padding: 6px 14px; border-radius: 999px; background: var(--bg-card); border: 1px solid var(--border);
    font-family: var(--mono); font-size: 11px; color: var(--text-dim); white-space: nowrap; }
  .gx-panel { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px 18px; min-height: 320px; }
  @media (max-width: 860px) {
