---
import WorldMap from '@components/WorldMap.astro';
import isoNumeric from '@data/iso-numeric.json';
import isoAlpha2 from '@data/iso-alpha2.json';
import { readFileSync } from 'node:fs';
import { createRequire } from 'node:module';
import { feature } from 'topojson-client';
import { geoNaturalEarth1, geoCentroid, geoPath } from 'd3-geo';

// Projected country centroids for the Bubbles view — same projection and
// frame as WorldMap, so bubbles start from each country's map position.
const requireHere = createRequire(import.meta.url);
const worldTopo = JSON.parse(readFileSync(requireHere.resolve('world-atlas/countries-110m.json'), 'utf8'));
const worldFc: any = feature(worldTopo, (worldTopo as any).objects.countries);
const bubbleProj = geoNaturalEarth1().fitSize([960, 480], worldFc);
// Faint world silhouette drawn behind the bubbles so it reads as a map.
// Per-country silhouettes (one <path> each, tagged with ISO3) so a country
// can be highlighted when its bubble is hovered.
const _bubblePath = geoPath(bubbleProj);
const bubbleCountries = worldFc.features
  .map((f: any) => ({ iso: (isoNumeric as any)[String(Number(f.id))], d: _bubblePath(f) }))
  .filter((c: any) => c.iso && c.d);
const centroids: Record<string, [number, number]> = {};
for (const f of worldFc.features) {
  const a3 = (isoNumeric as any)[String(Number(f.id))];
  if (!a3) continue;
  const c = bubbleProj(geoCentroid(f) as [number, number]);
  if (c) centroids[a3] = [Math.round(c[0]), Math.round(c[1])];
}
// Micro-states missing from the 110m geometry (Hong Kong tops several market
// indicators) — pin them by hand so they don't vanish from the bubble view.
const MICRO: Record<string, [number, number]> = {
  HKG: [114.17, 22.3], SGP: [103.85, 1.29], BHR: [50.55, 26.05], MLT: [14.4, 35.9],
  MUS: [57.55, -20.3], BRB: [-59.55, 13.1], MCO: [7.42, 43.73], LIE: [9.52, 47.14],
  AND: [1.52, 42.5], SMR: [12.45, 43.94], SYC: [55.45, -4.6], MDV: [73.5, 4.2], CPV: [-23.6, 15.1],
};
for (const [a3, ll] of Object.entries(MICRO)) {
  if (centroids[a3]) continue;
  const c = bubbleProj(ll as [number, number]);
  if (c) centroids[a3] = [Math.round(c[0]), Math.round(c[1])];
}

// Reusable interactive panel: indicator (optional) + period + country search +
// Bars/Table/Map views. Used by /explore (all indicators) and each dataset
// dashboard (pinned to one indicator).
export interface IndexItem {
  slug: string; title: string; kind: string; unit: string; valueLabel: string;
  changeMode: 'pct' | 'pp'; periods: string[];
}
interface Props { indicators: IndexItem[]; pinnedSlug?: string; defaultView?: 'bar' | 'table' | 'map' | 'bubbles' }
const { indicators, pinnedSlug, defaultView = 'bar' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const showIndicator = !pinnedSlug && indicators.length > 1;
// Default to a flagship indicator, not "datasets[0] after alphabetical sort" —
// that shifts to whatever obscure dataset title happens to sort first
// whenever a new one is added (e.g. "Acceptance of ..."), which reads as random.
const defaultSlug = indicators.some((d) => d.slug === 'whr-happiness') ? 'whr-happiness' : indicators[0]?.slug;
const config = { base, pinnedSlug: pinnedSlug ?? null, defaultSlug, defaultView, datasets: indicators };
---
<div class="datapanel">
  <div class="controls">
    {showIndicator && (
      <label>Indicator<select id="sel-indicator"></select></label>
    )}
    <label>Period<select id="sel-period"></select></label>
    <label>Search country<input id="sel-query" type="search" placeholder="filter…" autocomplete="off" /></label>
    <div class="view-toggle" id="view-toggle" role="tablist">
      <button data-view="bar" class="active">Bars</button>
      <button data-view="table">Table</button>
      <button data-view="map">Map</button>
      <button data-view="bubbles">Bubbles</button>
    </div>
  </div>

  <p class="sub" id="ex-summary"></p>

  <div id="view-bar" class="view">
    <div class="bar-controls" id="bar-controls">
      <label class="inline-add">Add country
        <select id="add-country"><option value="">＋ add…</option></select>
      </label>
      <span id="pinned-chips" class="chips"></span>
      <button type="button" id="sort-dir" class="ghost-btn" style="margin-left:auto">Highest first</button>
      <button type="button" id="show-all" class="ghost-btn" style="margin-left:0">Show all</button>
    </div>
    <div class="bars" id="bar-target"></div>
  </div>
  <div id="view-table" class="view" hidden><table class="data" id="table-target"></table></div>
  <div id="view-map" class="view" hidden><WorldMap /></div>
  <div id="view-bubbles" class="view" hidden>
    <svg id="bubble-target" viewBox="0 0 960 520" role="img" aria-label="Bubble map: circle area = indicator value" preserveAspectRatio="xMidYMid meet">
      <g transform="translate(0,20)">{bubbleCountries.map((c) => (<path class="bubble-basemap" data-iso={c.iso} d={c.d} />))}</g>
      <g id="bubble-nodes"></g>
    </svg>
    <div id="bubble-tip" hidden></div>
    <div class="map-legend" id="bubble-legend"></div>
  </div>
</div>

<script type="application/json" id="bd-config" set:html={JSON.stringify(config)}></script>
<script type="application/json" id="bd-centroids" set:html={JSON.stringify(centroids)}></script>
<script type="application/json" id="bd-iso" set:html={JSON.stringify(isoNumeric)}></script>
<script type="application/json" id="bd-a2" set:html={JSON.stringify(isoAlpha2)}></script>

<script>
  const cfg = JSON.parse(document.getElementById('bd-config').textContent);
  const isoNumeric = JSON.parse(document.getElementById('bd-iso').textContent); // numeric -> alpha3
  const isoAlpha2 = JSON.parse(document.getElementById('bd-a2').textContent);   // alpha3 -> alpha2
  const CENT = JSON.parse(document.getElementById('bd-centroids').textContent); // alpha3 -> [x,y]
  // Flag emoji from alpha-3; '' for aggregates/unknowns (decorative only).
  const flag = (iso) => { const a2 = iso && isoAlpha2[iso.toUpperCase()]; return a2 ? String.fromCodePoint(...[...a2].map((c) => 0x1f1e6 + c.charCodeAt(0) - 65)) + ' ' : ''; };
  const BASE = cfg.base;
  const el = (id) => document.getElementById(id);
  const selI = el('sel-indicator'), selP = el('sel-period'), selQ = el('sel-query');
  const TOP_N = 7;
  // "My countries" — a saved set that persists across datasets and sessions,
  // so the same countries stay pinned everywhere the panel is used.
  const MYKEY = 'bd-my-countries';
  const loadMy = () => { try { return new Set(JSON.parse(localStorage.getItem(MYKEY) || '[]')); } catch (e) { return new Set(); } };
  const saveMy = () => { try { localStorage.setItem(MYKEY, JSON.stringify([...state.pinned])); } catch (e) { /* private mode */ } };
  const state = { slug: cfg.pinnedSlug || cfg.defaultSlug || cfg.datasets[0]?.slug, period: null, view: cfg.defaultView || 'bar', query: '', pinned: loadMy(), showAll: false, sortDir: 'desc' };
  const cache = new Map();
  const meta = () => cfg.datasets.find((d) => d.slug === state.slug);

  // ---- deep-link state from the URL ----
  const params = new URLSearchParams(location.search);
  if (!cfg.pinnedSlug && params.get('i') && cfg.datasets.some((d) => d.slug === params.get('i'))) state.slug = params.get('i');
  if (['bar', 'table', 'map', 'bubbles'].includes(params.get('v'))) state.view = params.get('v');
  function syncUrl() {
    const p = new URLSearchParams(location.search);
    if (!cfg.pinnedSlug) p.set('i', state.slug);
    if (state.period) p.set('p', state.period);
    p.set('v', state.view);
    history.replaceState(null, '', location.pathname + '?' + p.toString() + location.hash);
  }

  if (selI) {
    for (const kind of ['macro', 'survey']) {
      const items = cfg.datasets.filter((x) => x.kind === kind);
      if (!items.length) continue;
      const g = document.createElement('optgroup');
      g.label = kind === 'macro' ? 'Macro' : 'Polls';
      for (const d of items) { const o = document.createElement('option'); o.value = d.slug; o.textContent = d.title; g.appendChild(o); }
      selI.appendChild(g);
    }
    selI.value = state.slug;
    selI.addEventListener('change', () => { state.slug = selI.value; state.showAll = false; fillPeriods(); render(); });
  }

  let initialPeriod = params.get('p');
  function fillPeriods() {
    const m = meta(); selP.innerHTML = '';
    for (const p of m.periods) { const o = document.createElement('option'); o.value = p; o.textContent = p; selP.appendChild(o); }
    state.period = (initialPeriod && m.periods.includes(initialPeriod)) ? initialPeriod : m.periods[m.periods.length - 1];
    initialPeriod = null; // only honour the URL period on first load
    selP.value = state.period;
  }

  async function load(slug) {
    if (cache.has(slug)) return cache.get(slug);
    const ds = await (await fetch(`${BASE}/data/${slug}.json`)).json();
    cache.set(slug, ds); return ds;
  }

  const changeVal = (cv, pv, mode) => mode === 'pp' ? cv - pv : (pv ? (cv - pv) / pv * 100 : 0);
  const fmtChange = (v, mode) => (v > 0 ? '+' : '') + v.toFixed(Math.abs(v) < 1 ? 2 : 1) + (mode === 'pp' ? 'pp' : '%');
  const fmtNum = (n) => n.toLocaleString('en-US', { maximumFractionDigits: 1 });
  const moveClass = (v) => v > 0.5 ? 'up' : v < -0.5 ? 'down' : 'flat';

  function rowsFor(ds) {
    const m = meta();
    const idx = m.periods.indexOf(state.period);
    const prevP = idx > 0 ? m.periods[idx - 1] : null;
    const byEnt = new Map();
    for (const o of ds.data) {
      let r = byEnt.get(o.entity);
      if (!r) byEnt.set(o.entity, r = { entity: o.entity, group: o.group, iso: o.iso });
      if (o.period === state.period) r.value = o.value;
      if (o.period === prevP) r.prev = o.value;
    }
    let rows = [...byEnt.values()].filter((r) => r.value != null);
    rows.forEach((r) => { r.change = r.prev != null ? changeVal(r.value, r.prev, m.changeMode) : null; });
    if (state.query) { const q = state.query.toLowerCase(); rows = rows.filter((r) => r.entity.toLowerCase().includes(q) || (r.group || '').toLowerCase().includes(q)); }
    return rows.sort((a, b) => b.value - a.value);
  }

  function visibleRows(rows) {
    const ordered = state.sortDir === 'asc' ? [...rows].reverse() : rows; // rows is desc by value
    if (state.query) return ordered;            // search overrides the limit
    if (state.showAll) return ordered;
    const top = ordered.slice(0, TOP_N);
    const names = new Set(top.map((r) => r.entity));
    const extra = ordered.filter((r) => state.pinned.has(r.entity) && !names.has(r.entity));
    return [...top, ...extra].sort((a, b) => state.sortDir === 'asc' ? a.value - b.value : b.value - a.value);
  }

  function renderBarControls(rows) {
    const sel = el('add-country');
    const ordered = state.sortDir === 'asc' ? [...rows].reverse() : rows;
    const shown = new Set(ordered.slice(0, TOP_N).map((r) => r.entity));
    sel.innerHTML = '<option value="">＋ add country…</option>' +
      [...rows].sort((a, b) => a.entity.localeCompare(b.entity))
        .filter((r) => !shown.has(r.entity) && !state.pinned.has(r.entity))
        .map((r) => `<option value="${r.entity}">${r.entity}</option>`).join('');
    el('pinned-chips').innerHTML = (state.pinned.size ? '<span class="chips-lbl">★ My countries:</span>' : '') +
      [...state.pinned].map((n) =>
        `<span class="chip">${n}<button data-rm="${n}" aria-label="remove">×</button></span>`).join('');
    el('sort-dir').textContent = state.sortDir === 'asc' ? 'Lowest first' : 'Highest first';
    el('show-all').textContent = state.showAll ? 'Show top 7' : `Show all ${rows.length}`;
    el('bar-controls').style.display = state.query ? 'none' : 'flex';
  }

  function renderBars(rows) {
    const m = meta(); const unit = m.unit.includes('%') ? '%' : '';
    renderBarControls(rows);
    const top = visibleRows(rows); const vals = top.map((r) => r.value);
    const base = Math.min(0, ...vals), max = Math.max(1, ...vals), span = (max - base) || 1;
    el('bar-target').innerHTML = top.map((r) => {
      const w = Math.max(0, Math.min(100, (r.value - base) / span * 100));
      const cls = r.change == null ? 'flat' : moveClass(r.change);
      const chg = r.change == null ? '' : `<em class="${cls}">${fmtChange(r.change, m.changeMode)}</em>`;
      return `<div class="bar-row"><span>${flag(r.iso)}${r.entity}</span><span class="bar-track"><span class="bar-fill move-${cls}" style="width:${w}%"></span></span><span class="bar-val">${fmtNum(r.value)}${unit}${chg}</span></div>`;
    }).join('');
  }

  function renderTable(rows) {
    const m = meta(); const unit = m.unit.includes('%') ? '%' : '';
    const head = `<thead><tr><th>Country</th><th>Group</th><th class="num">${m.valueLabel}</th><th class="num">Change</th></tr></thead>`;
    el('table-target').innerHTML = head + '<tbody>' + rows.map((r) => {
      const cls = r.change == null ? 'flat' : moveClass(r.change);
      const chg = r.change == null ? '—' : `<span class="${cls}">${fmtChange(r.change, m.changeMode)}</span>`;
      return `<tr><td>${flag(r.iso)}${r.entity}</td><td>${r.group || ''}</td><td class="num">${fmtNum(r.value)}${unit}</td><td class="num">${chg}</td></tr>`;
    }).join('') + '</tbody>';
  }

  const mix = (a, b, t) => { t = Math.max(0, Math.min(1, t)); const c = a.map((x, i) => Math.round(x + (b[i] - x) * t)); return `rgb(${c[0]},${c[1]},${c[2]})`; };
  const DARK = [28, 31, 35], AMBER = [255, 176, 0], GREY = [70, 74, 82], RED = [248, 113, 113], GREEN = [52, 211, 153];

  function renderMap(rows) {
    const m = meta(); const unit = m.unit.includes('%') ? '%' : '';
    const byIso = new Map(); for (const r of rows) if (r.iso) byIso.set(r.iso, r.value);
    const vals = [...byIso.values()]; const min = Math.min(...vals), max = Math.max(...vals);
    const diverging = min < 0 && max > 0; // signed indicator → red ↔ green around zero
    // Shade by rank, not raw value: one outlier (Hong Kong at 1,114% of GDP)
    // would otherwise squash every other country into near-background black.
    const sorted = [...vals].sort((a, b) => a - b);
    const rankT = (v) => sorted.length > 1 ? sorted.indexOf(v) / (sorted.length - 1) : 1;
    const colorFor = (v) => diverging
      ? (v < 0 ? mix(GREY, RED, v / min) : mix(GREY, GREEN, v / max))
      : mix(DARK, AMBER, 0.08 + 0.92 * rankT(v));
    el('view-map').querySelectorAll('.country').forEach((p) => {
      // data-num is zero-padded ("076"); iso-numeric keys are unpadded ("76")
      const iso = isoNumeric[String(Number(p.getAttribute('data-num')))];
      const v = iso != null ? byIso.get(iso) : undefined;
      if (v == null) { p.setAttribute('fill', 'var(--bg-elev)'); p.style.opacity = '0.5'; }
      else { p.setAttribute('fill', colorFor(v)); p.style.opacity = '1'; }
    });
    const bar = diverging
      ? 'linear-gradient(90deg,#f87171,#464a52,#34d399)'
      : 'linear-gradient(90deg,var(--bg-card),var(--accent))';
    el('map-legend').innerHTML = `<span>${isFinite(min) ? fmtNum(min) : '—'}${unit}</span><span class="legend-bar" style="background:${bar}"></span><span>${isFinite(max) ? fmtNum(max) : '—'}${unit}</span><span class="legend-label">${m.valueLabel} · ${state.period}${diverging ? ' · 0-centred' : ' · shaded by rank'}</span>`;
  }

  // Dorling-style bubble map: a circle per country, area = value, anchored at
  // the country's map position and gently pushed apart until nothing overlaps.
  function renderBubbles(rows) {
    const m = meta(); const unit = m.unit.includes('%') ? '%' : '';
    const data = rows.map((r, i) => ({ ...r, rank: i + 1 })).filter((r) => r.iso && CENT[r.iso]).slice(0, 60);
    // reset any lingering hover highlight from a previous indicator/period
    el('bubble-nodes').classList.remove('focus');
    el('view-bubbles').querySelectorAll('.bubble-basemap.hl').forEach((p) => p.classList.remove('hl'));
    if (!data.length) { el('bubble-nodes').innerHTML = ''; el('bubble-legend').innerHTML = '<span class="legend-label">No countries with map positions for this indicator.</span>'; return; }
    const signed = data.some((r) => r.value < 0);
    const maxV = Math.max(...data.map((r) => Math.abs(r.value))) || 1;
    const W = 960, H = 520, MAXR = 54, MINR = 4;
    // pow 0.4 instead of a strict sqrt: one outlier (Hong Kong at 1,114%)
    // would otherwise shrink everyone else into unlabelled dots
    const nodes = data.map((r) => ({ ...r,
      x: CENT[r.iso][0], y: CENT[r.iso][1] + 20,
      r: Math.max(MINR, Math.pow(Math.abs(r.value) / maxV, 0.4) * MAXR) }));
    for (let it = 0; it < 70; it++) {
      for (let i = 0; i < nodes.length; i++) for (let j = i + 1; j < nodes.length; j++) {
        const a = nodes[i], b = nodes[j];
        let dx = b.x - a.x, dy = b.y - a.y;
        const d = Math.hypot(dx, dy) || 0.001, min = a.r + b.r + 1.5;
        if (d < min) { const push = (min - d) / 2; dx /= d; dy /= d; a.x -= dx * push; a.y -= dy * push; b.x += dx * push; b.y += dy * push; }
      }
      for (const n of nodes) { n.x = Math.max(n.r + 2, Math.min(W - n.r - 2, n.x)); n.y = Math.max(n.r + 2, Math.min(H - n.r - 2, n.y)); }
    }
    const absSorted = data.map((r) => Math.abs(r.value)).sort((x, y) => x - y);
    const rankT = (v) => absSorted.length > 1 ? absSorted.indexOf(Math.abs(v)) / (absSorted.length - 1) : 1;
    el('bubble-target').dataset.lbl = m.valueLabel;
    el('bubble-nodes').innerHTML = nodes.map((n) => {
      const t = signed ? Math.abs(n.value) / maxV : 0.15 + 0.85 * rankT(n.value);
      const col = signed ? (n.value < 0 ? mix(GREY, RED, Math.abs(n.value) / maxV) : mix(GREY, GREEN, n.value / maxV)) : mix(DARK, AMBER, t);
      const dark = !signed && t > 0.55;
      const txt = dark ? '#1a1300' : '#e7e9ec';
      const a2 = isoAlpha2[n.iso] || n.iso.slice(0, 2);
      const showCode = n.r > 9, showVal = n.r > 19;
      const ent = String(n.entity).replace(/"/g, '&quot;');
      return `<g transform="translate(${n.x.toFixed(1)},${n.y.toFixed(1)})" data-e="${ent}" data-iso="${n.iso}"` +
        ` data-v="${fmtNum(n.value)}${unit}" data-r="#${n.rank} of ${rows.length}"` +
        ` data-c="${n.change == null ? '' : fmtChange(n.change, m.changeMode)}" data-g="${n.group || ''}">` +
        `<circle r="${n.r.toFixed(1)}" fill="${col}" fill-opacity="0.94" stroke="rgba(0,0,0,0.35)" stroke-width="1"></circle>` +
        (showCode ? `<text class="bub-t" fill="${txt}" y="${showVal ? -2.5 : 4}">${a2}</text>` : '') +
        (showVal ? `<text class="bub-v" fill="${txt}" y="12">${fmtNum(n.value)}${unit}</text>` : '') + `</g>`;
    }).join('');
    el('bubble-legend').innerHTML = `<span class="legend-label">${m.valueLabel} · ${state.period} · bubble size = value · top ${nodes.length} of ${rows.length} countries · hover or tap a bubble</span>`;
  }

  // Bubble tooltip: hover for the full story, click/tap to pin it.
  {
    const btgt = el('bubble-target'), btip = el('bubble-tip'), bwrap = el('view-bubbles');
    let pinned = false;
    let hlPath = null;
    const clearFocus = () => {
      if (hlPath) { hlPath.classList.remove('hl'); hlPath = null; }
      const nodes = el('bubble-nodes'); nodes.classList.remove('focus');
      nodes.querySelectorAll('g[data-e]').forEach((x) => { x.classList.remove('hot'); x.style.opacity = ''; });
    };
    const focusOn = (g) => {
      const nodes = el('bubble-nodes');
      // dim the others directly (SVG <g> opacity via the CSS cascade is flaky)
      nodes.querySelectorAll('g[data-e]').forEach((x) => { x.style.opacity = x === g ? '1' : '0.28'; x.classList.toggle('hot', x === g); });
      nodes.classList.add('focus');
      if (hlPath) hlPath.classList.remove('hl');
      const p = btgt.querySelector('.bubble-basemap[data-iso="' + g.dataset.iso + '"]');
      if (p) { p.classList.add('hl'); hlPath = p; } else hlPath = null;
    };
    const show = (g, ev) => {
      focusOn(g);
      const d = g.dataset;
      btip.innerHTML = `<b>${flag(d.iso)}${d.e}</b>` +
        `<div class="tr"><span>${btgt.dataset.lbl || 'Value'}</span><b>${d.v}</b></div>` +
        `<div class="tr"><span>Rank</span><b>${d.r}</b></div>` +
        (d.c ? `<div class="tr"><span>vs previous period</span><b>${d.c}</b></div>` : '') +
        (d.g ? `<div class="tr"><span>Region</span><b>${d.g}</b></div>` : '');
      btip.hidden = false;
      const r = bwrap.getBoundingClientRect();
      const x = ev.clientX - r.left, y = ev.clientY - r.top;
      btip.style.left = Math.max(4, Math.min(x + 14, r.width - btip.offsetWidth - 8)) + 'px';
      btip.style.top = Math.max(y - btip.offsetHeight - 12, 4) + 'px';
    };
    btgt.addEventListener('mousemove', (e) => {
      if (pinned) return;
      const g = e.target.closest('g[data-e]');
      if (g) show(g, e); else { btip.hidden = true; clearFocus(); }
    });
    btgt.addEventListener('mouseleave', () => { if (!pinned) { btip.hidden = true; clearFocus(); } });
    btgt.addEventListener('click', (e) => {
      const g = e.target.closest('g[data-e]');
      if (g) { pinned = true; show(g, e); } else { pinned = false; btip.hidden = true; clearFocus(); }
    });
  }

  async function render() {
    const ds = await load(state.slug); const m = meta(); const rows = rowsFor(ds);
    el('ex-summary').textContent = `${m.title} · ${state.period} · ${rows.length} countries · unit ${m.unit}`;
    for (const v of ['bar', 'table', 'map', 'bubbles']) el('view-' + v).hidden = state.view !== v;
    if (state.view === 'bar') renderBars(rows); else if (state.view === 'table') renderTable(rows); else if (state.view === 'bubbles') renderBubbles(rows); else renderMap(rows);
    syncUrl();
  }

  selP.addEventListener('change', () => { state.period = selP.value; render(); });
  selQ.addEventListener('input', () => { state.query = selQ.value.trim(); render(); });
  el('add-country').addEventListener('change', (e) => { if (e.target.value) { state.pinned.add(e.target.value); saveMy(); render(); } });
  el('pinned-chips').addEventListener('click', (e) => { const n = e.target.getAttribute('data-rm'); if (n) { state.pinned.delete(n); saveMy(); render(); } });
  el('show-all').addEventListener('click', () => { state.showAll = !state.showAll; render(); });
  el('sort-dir').addEventListener('click', () => { state.sortDir = state.sortDir === 'asc' ? 'desc' : 'asc'; render(); });
  el('view-toggle').addEventListener('click', (e) => {
    const b = e.target.closest('button'); if (!b) return;
    state.view = b.dataset.view;
    [...el('view-toggle').children].forEach((x) => x.classList.toggle('active', x === b));
    render();
  });

  // reflect restored view in the toggle
  [...el('view-toggle').children].forEach((x) => x.classList.toggle('active', x.dataset.view === state.view));
  fillPeriods();
  render();
</script>
