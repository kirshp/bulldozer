---
import type { Observation, ChangeMode } from '@lib/analytics';
import { groupRollups } from '@lib/analytics';
import { formatChange } from '@lib/format';

// Diverging bar chart of period-over-period change per group — the web port of
// the Madeira dashboard trend chart (green = up, red = down, from a zero axis).
interface Props { data: Observation[]; mode?: ChangeMode }
const { data, mode = 'pct' } = Astro.props;
const groups = groupRollups(data, mode).sort((a, b) => b.pct - a.pct);
const maxAbs = Math.max(1, ...groups.map((g) => Math.abs(g.pct)));
const half = (pct: number) => (Math.abs(pct) / maxAbs) * 50;
---
<div class="gchart">
  {groups.map((g) => (
    <div class="gchart-row">
      <span>{g.group}</span>
      <span class="gchart-rail">
        <span class="gchart-zero"></span>
        <span class={`gchart-bar ${g.pct >= 0 ? 'pos' : 'neg'}`} style={`width:${half(g.pct)}%`}></span>
      </span>
      <span class={`gchart-val ${g.pct > 0 ? 'up' : g.pct < 0 ? 'down' : 'flat'}`}>{formatChange(g.pct, mode)}</span>
    </div>
  ))}
</div>
