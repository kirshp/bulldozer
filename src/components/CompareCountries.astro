---
import { TOPICS, TOPIC_ORDER } from '@lib/topics';
import isoAlpha2 from '@data/iso-alpha2.json';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const topicMeta = TOPIC_ORDER.map((id) => ({ id, label: TOPICS[id].label, icon: TOPICS[id].icon }));
---
<div class="compare">
  <div class="controls">
    <label>Add country<select id="cmp-add"><option value="">＋ add…</option></select></label>
    <span id="cmp-chips" class="chips"></span>
  </div>
  <div id="cmp-table" style="overflow-x:auto; margin-top:8px"></div>
</div>

<script type="application/json" id="cmp-topics" set:html={JSON.stringify(topicMeta)}></script>
<script type="application/json" id="cmp-a2" set:html={JSON.stringify(isoAlpha2)}></script>
<script define:vars={{ base }}>
  const TOPICS = JSON.parse(document.getElementById('cmp-topics').textContent);
  const isoAlpha2 = JSON.parse(document.getElementById('cmp-a2').textContent);
  const flag = (iso) => { const a2 = iso && isoAlpha2[iso.toUpperCase()]; return a2 ? String.fromCodePoint(...[...a2].map((c) => 0x1f1e6 + c.charCodeAt(0) - 65)) + ' ' : ''; };
  const add = document.getElementById('cmp-add');
  const chipsEl = document.getElementById('cmp-chips');
  const tableEl = document.getElementById('cmp-table');
  let countries = [], byIso = {};
  const fmtNum = (n) => n.toLocaleString('en-US', { maximumFractionDigits: 1 });

  const params = new URLSearchParams(location.search);
  let selected = (params.get('cmp') || 'USA,CHN,DEU').split(',').filter(Boolean);

  function syncUrl() {
    const p = new URLSearchParams(location.search);
    p.set('cmp', selected.join(','));
    history.replaceState(null, '', location.pathname + '?' + p.toString() + location.hash);
  }

  function renderChips() {
    chipsEl.innerHTML = selected.map((iso) =>
      `<span class="chip">${flag(iso)}${(byIso[iso] || {}).name || iso}<button data-rm="${iso}">×</button></span>`).join('');
    add.innerHTML = '<option value="">＋ add country…</option>' +
      countries.filter((c) => !selected.includes(c.iso))
        .map((c) => `<option value="${c.iso}">${flag(c.iso)}${c.name}</option>`).join('');
  }

  function renderTable() {
    const cols = selected.map((iso) => byIso[iso]).filter(Boolean);
    if (!cols.length) { tableEl.innerHTML = '<p class="sub">Add a country to compare.</p>'; return; }
    // union of indicators, keyed by slug → {title, topic, unit}
    const ind = new Map();
    for (const c of cols) for (const it of c.items) if (!ind.has(it.slug)) ind.set(it.slug, it);
    let html = `<table class="data"><thead><tr><th>Indicator</th>${cols.map((c) => `<th class="num">${flag(c.iso)}${c.name}</th>`).join('')}</tr></thead><tbody>`;
    for (const t of TOPICS) {
      const rows = [...ind.values()].filter((i) => i.topic === t.id).sort((a, b) => a.title.localeCompare(b.title));
      if (!rows.length) continue;
      html += `<tr><td colspan="${cols.length + 1}" style="padding-top:16px;color:var(--text-dim);font-size:12px;text-transform:uppercase;letter-spacing:1px">${t.icon} ${t.label}</td></tr>`;
      for (const r of rows) {
        const vals = cols.map((c) => { const it = c.items.find((x) => x.slug === r.slug); return it ? it.value : null; });
        const max = Math.max(...vals.filter((v) => v != null));
        const unit = r.unit && r.unit.includes('%') ? '%' : '';
        html += `<tr><td><a href="${base}/dataset/${r.slug}">${r.title}</a></td>` +
          vals.map((v) => v == null ? '<td class="num" style="color:var(--text-dim)">—</td>'
            : `<td class="num"${v === max ? ' style="color:var(--accent);font-weight:600"' : ''}>${fmtNum(v)}${unit}</td>`).join('') + '</tr>';
      }
    }
    tableEl.innerHTML = html + '</tbody></table>';
  }

  function render() { renderChips(); renderTable(); syncUrl(); }

  add.addEventListener('change', () => { if (add.value && selected.length < 5 && !selected.includes(add.value)) { selected.push(add.value); render(); } });
  chipsEl.addEventListener('click', (e) => { const iso = e.target.getAttribute('data-rm'); if (iso) { selected = selected.filter((x) => x !== iso); render(); } });

  fetch(`${base}/data/country-index.json`).then((r) => r.json()).then((data) => {
    countries = data; byIso = Object.fromEntries(data.map((c) => [c.iso, c]));
    selected = selected.filter((iso) => byIso[iso]);
    if (!selected.length) selected = data.slice(0, 3).map((c) => c.iso);
    render();
  });
</script>
