---
import { getDataset } from '@data/datasets';
import { countryPaths, MAP_W, MAP_H } from '@lib/worldgeo';
import { bivColor, terciles, classify } from '@lib/bivariate';
import isoNumeric from '@data/iso-numeric.json';

interface Props { xSlug: string; ySlug: string; title?: string }
const { xSlug, ySlug, title } = Astro.props;

const xDs = getDataset(xSlug)!;
const yDs = getDataset(ySlug)!;
const latest = (ds: any) => {
  const p = [...new Set(ds.data.map((o: any) => o.period))].sort();
  const period = p[p.length - 1];
  const m = new Map<string, number>();
  for (const o of ds.data) if (o.period === period && o.iso) m.set(o.iso, o.value);
  return m;
};
const xByIso = latest(xDs);
const yByIso = latest(yDs);

const common = [...xByIso.keys()].filter((iso) => yByIso.has(iso));
const xT = terciles(common.map((iso) => xByIso.get(iso)!));
const yT = terciles(common.map((iso) => yByIso.get(iso)!));

const num2iso = isoNumeric as Record<string, string>;
const fillFor = (num: string) => {
  const iso = num2iso[num];
  if (!iso || !xByIso.has(iso) || !yByIso.has(iso)) return null;
  return bivColor(classify(xByIso.get(iso)!, xT), classify(yByIso.get(iso)!, yT));
};

// 3×3 legend cells (yi from 2 top to 0 bottom)
const legendRows = [2, 1, 0].map((yi) => [0, 1, 2].map((xi) => bivColor(xi, yi)));
---
<div class="bivmap">
  {title && <p class="sub" style="margin-bottom:10px">{title}</p>}
  <div class="bivmap-grid">
    <div class="worldmap">
      <svg viewBox={`0 0 ${MAP_W} ${MAP_H}`} role="img" aria-label={`${xDs.title} vs ${yDs.title}`} preserveAspectRatio="xMidYMid meet">
        {countryPaths.map((c) => {
          const f = fillFor(c.num);
          return <path class="country" d={c.d} fill={f ?? 'var(--bg-elev)'} fill-opacity={f ? 1 : 0.45} stroke="var(--bg)" stroke-width="0.4"><title>{c.name}</title></path>;
        })}
      </svg>
    </div>
    <div class="biv-legend">
      <div class="biv-yaxis">{yDs.valueLabel} →</div>
      <div class="biv-matrix">
        {legendRows.map((row) => (
          <div class="biv-mrow">{row.map((c) => <span class="biv-cell" style={`background:${c}`}></span>)}</div>
        ))}
      </div>
      <div class="biv-xaxis">{xDs.valueLabel} →</div>
    </div>
  </div>
</div>
