---
import type { Observation } from '@lib/analytics';
import { colorFor } from '@lib/palette';

interface Props { data: Observation[]; unit?: string }
const { data, unit = '' } = Astro.props;

const periods = [...new Set(data.map((o) => o.period))].sort();
const groups = [...new Set(data.map((o) => o.group).filter(Boolean) as string[])];

// group → period → mean
const series = groups.map((g) => {
  const pts = periods.map((p) => {
    const vals = data.filter((o) => o.group === g && o.period === p).map((o) => o.value);
    return vals.length ? vals.reduce((a, b) => a + b, 0) / vals.length : null;
  });
  return { group: g, pts };
});

const allVals = series.flatMap((s) => s.pts).filter((v): v is number => v != null);
const yMin = Math.min(...allVals), yMax = Math.max(...allVals);
const pad = (yMax - yMin) * 0.08 || 1;
const lo = yMin - pad, hi = yMax + pad;

const W = 760, H = 340, m = { t: 16, r: 16, b: 34, l: 48 };
const iw = W - m.l - m.r, ih = H - m.t - m.b;
const X = (i: number) => m.l + (periods.length === 1 ? iw / 2 : (i / (periods.length - 1)) * iw);
const Y = (v: number) => m.t + ih - ((v - lo) / (hi - lo || 1)) * ih;
const yTicks = Array.from({ length: 5 }, (_, i) => Math.round((lo + ((hi - lo) * i) / 4) * 10) / 10);
const path = (pts: (number | null)[]) => pts.map((v, i) => v == null ? '' : `${i === 0 || pts[i - 1] == null ? 'M' : 'L'}${X(i).toFixed(1)},${Y(v).toFixed(1)}`).join(' ');
---
<div class="chart-svg">
  <svg viewBox={`0 0 ${W} ${H}`} role="img" aria-label="Trend by group">
    {yTicks.map((v) => (
      <g><line x1={m.l} y1={Y(v)} x2={W - m.r} y2={Y(v)} stroke="var(--border)" /><text x={m.l - 8} y={Y(v) + 4} text-anchor="end" class="axis">{v}{unit}</text></g>
    ))}
    {periods.map((p, i) => (i % Math.ceil(periods.length / 8) === 0 || i === periods.length - 1) && (
      <text x={X(i)} y={H - m.b + 20} text-anchor="middle" class="axis">{p}</text>
    ))}
    {series.map((s) => (
      <path d={path(s.pts)} fill="none" stroke={colorFor(s.group)} stroke-width="2.2" stroke-linejoin="round" stroke-linecap="round" />
    ))}
  </svg>
  <div class="legend-regions">
    {series.map((s) => (<span class="lr"><span class="lr-dot" style={`background:${colorFor(s.group)}`}></span>{s.group}</span>))}
  </div>
</div>
