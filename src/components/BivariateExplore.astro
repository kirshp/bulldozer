---
import WorldMap from '@components/WorldMap.astro';
import isoNumeric from '@data/iso-numeric.json';
export interface IndexItem { slug: string; title: string; kind: string }
interface Props { indicators: IndexItem[] }
const { indicators } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const config = { base, indicators };
---
<div class="bivexplore">
  <div class="controls">
    <label>X (amber →)<select id="biv-x"></select></label>
    <label>Y (blue ↑)<select id="biv-y"></select></label>
  </div>

  <div class="bivmap-grid" style="margin-top:8px">
    <div id="biv-map"><WorldMap legendId="biv-unused" showLegend={false} /></div>
    <div class="biv-legend">
      <div class="biv-yaxis" id="biv-ylabel">Y →</div>
      <div class="biv-matrix" id="biv-matrix"></div>
      <div class="biv-xaxis" id="biv-xlabel">X →</div>
    </div>
  </div>
  <p class="sub" id="biv-summary" style="margin-top:10px"></p>
</div>

<script type="application/json" id="biv-config" set:html={JSON.stringify(config)}></script>
<script type="application/json" id="biv-iso" set:html={JSON.stringify(isoNumeric)}></script>
<script>
  const cfg = JSON.parse(document.getElementById('biv-config').textContent);
  const isoNumeric = JSON.parse(document.getElementById('biv-iso').textContent);
  const BASE = cfg.base;
  const elx = document.getElementById('biv-x'), ely = document.getElementById('biv-y');
  let countries = [];

  const B = [40, 42, 48], A = [255, 176, 0], BL = [80, 140, 230];
  const bivColor = (xi, yi) => { const c = B.map((v, i) => Math.max(0, Math.min(255, Math.round(v + (A[i] - B[i]) * (xi / 2) + (BL[i] - B[i]) * (yi / 2))))); return `rgb(${c[0]},${c[1]},${c[2]})`; };
  const terc = (vals) => { const s = [...vals].sort((a, b) => a - b); const q = (p) => s[Math.min(s.length - 1, Math.floor(p * s.length))]; return [q(1 / 3), q(2 / 3)]; };
  const cls = (v, t) => v <= t[0] ? 0 : v <= t[1] ? 1 : 2;

  function fillSelect(sel, def) {
    for (const kind of ['macro', 'survey']) {
      const items = cfg.indicators.filter((x) => x.kind === kind);
      const g = document.createElement('optgroup'); g.label = kind === 'macro' ? 'Macro' : 'Study';
      for (const d of items) { const o = document.createElement('option'); o.value = d.slug; o.textContent = d.title; g.appendChild(o); }
      sel.appendChild(g);
    }
    sel.value = def;
  }
  const title = (slug) => (cfg.indicators.find((d) => d.slug === slug) || {}).title || slug;

  function render() {
    const xs = elx.value, ys = ely.value;
    const xMap = new Map(), yMap = new Map();
    for (const c of countries) {
      const xi = c.items.find((i) => i.slug === xs); const yi = c.items.find((i) => i.slug === ys);
      if (xi) xMap.set(c.iso, xi.value); if (yi) yMap.set(c.iso, yi.value);
    }
    const common = [...xMap.keys()].filter((iso) => yMap.has(iso));
    const xt = terc(common.map((i) => xMap.get(i))), yt = terc(common.map((i) => yMap.get(i)));
    document.querySelectorAll('#biv-map .country').forEach((p) => {
      const iso = isoNumeric[p.getAttribute('data-num')];
      if (iso && xMap.has(iso) && yMap.has(iso)) { p.setAttribute('fill', bivColor(cls(xMap.get(iso), xt), cls(yMap.get(iso), yt))); p.style.opacity = '1'; }
      else { p.setAttribute('fill', 'var(--bg-elev)'); p.style.opacity = '0.45'; }
    });
    // legend
    const rows = [2, 1, 0].map((yi) => [0, 1, 2].map((xi) => bivColor(xi, yi)));
    document.getElementById('biv-matrix').innerHTML = rows.map((r) => `<div class="biv-mrow">${r.map((c) => `<span class="biv-cell" style="background:${c}"></span>`).join('')}</div>`).join('');
    document.getElementById('biv-xlabel').textContent = `${title(xs)} →`;
    document.getElementById('biv-ylabel').textContent = `${title(ys)} →`;
    document.getElementById('biv-summary').textContent = `${common.length} countries with both indicators · darker = low, brighter = high`;
  }

  function syncUrl() {
    const p = new URLSearchParams(location.search);
    p.set('bx', elx.value); p.set('by', ely.value);
    history.replaceState(null, '', location.pathname + '?' + p.toString() + location.hash);
  }
  elx.addEventListener('change', () => { render(); syncUrl(); });
  ely.addEventListener('change', () => { render(); syncUrl(); });
  const bp = new URLSearchParams(location.search);
  const valid = (s) => cfg.indicators.some((d) => d.slug === s);
  fillSelect(elx, valid(bp.get('bx')) ? bp.get('bx') : 'whr-happiness');
  fillSelect(ely, valid(bp.get('by')) ? bp.get('by') : 'imf-gdp-per-capita-ppp');
  fetch(`${BASE}/data/country-index.json`).then((r) => r.json()).then((d) => { countries = d; render(); });
</script>
