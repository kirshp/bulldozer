---
// Three "beyond bars" views of a single indicator: beeswarm (full distribution),
// slope (change between first & last year) and an animated bar-chart race.
export interface IndexItem { slug: string; title: string; unit: string; kind: string }
interface Props { indicators: IndexItem[] }
const { indicators } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const has = (s: string) => indicators.some((d) => d.slug === s);
const config = {
  base,
  indicators: indicators.map((d) => ({ slug: d.slug, title: d.title, unit: d.unit })),
  def: has('whr-happiness') ? 'whr-happiness' : indicators[0]?.slug,
};
---
<div class="siv">
  <div class="controls">
    <label>Indicator<select id="siv-ind"></select></label>
    <span class="view-toggle" id="siv-type">
      <button type="button" data-t="beeswarm" class="active">Beeswarm</button>
      <button type="button" data-t="slope">Slope</button>
      <button type="button" data-t="race">Bar race</button>
    </span>
    <button type="button" id="siv-play" class="ghost-btn" hidden style="margin:0">▶ Play</button>
  </div>
  <div class="bub-stage">
    <svg id="siv-svg" viewBox="0 0 900 440" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Indicator chart"></svg>
    <div id="siv-tip" class="bub-tip" hidden></div>
  </div>
  <div class="legend-regions" id="siv-legend"></div>
  <p class="sub" id="siv-note" style="margin-top:8px"></p>
</div>
<script type="application/json" id="siv-config" set:html={JSON.stringify(config)}></script>
<script>
  const cfg = JSON.parse(document.getElementById('siv-config').textContent);
  const BASE = cfg.base, NS = 'http://www.w3.org/2000/svg';
  const REGION = { Africa: '#fbbf24', Americas: '#e0567b', Asia: '#34d399', Europe: '#508ce6', Other: '#9ca3af' };
  const el = (id) => document.getElementById(id);
  const svg = el('siv-svg'), tip = el('siv-tip');
  const W = 900, H = 440, M = { l: 56, r: 24, t: 18, b: 40 };
  const PW = W - M.l - M.r, PH = H - M.t - M.b;
  const cache = new Map();
  const state = { slug: cfg.def, type: 'beeswarm', ds: null, playing: false, timer: null, raceYear: null };

  // ---- deep-link state from the URL ----
  const sq = new URLSearchParams(location.search);
  if (cfg.indicators.some((d) => d.slug === sq.get('di'))) state.slug = sq.get('di');
  if (['beeswarm', 'slope', 'race'].includes(sq.get('dt'))) state.type = sq.get('dt');
  function syncUrl() {
    const p = new URLSearchParams(location.search);
    p.set('di', state.slug); p.set('dt', state.type);
    history.replaceState(null, '', location.pathname + '?' + p.toString() + location.hash);
  }
  const titleOf = (s) => (cfg.indicators.find((d) => d.slug === s) || {}).title || s;
  const fmt = (n) => Math.abs(n) >= 1000 ? n.toLocaleString('en-US', { maximumFractionDigits: 0 }) : n.toLocaleString('en-US', { maximumFractionDigits: 1 });

  async function load(slug) {
    if (cache.has(slug)) return cache.get(slug);
    const ds = await (await fetch(`${BASE}/data/${slug}.json`)).json();
    cache.set(slug, ds.data); return ds.data;
  }
  const periodsOf = (data) => [...new Set(data.map((o) => o.period))].sort();
  const atYear = (data, p) => data.filter((o) => o.period === p && o.iso && o.value != null);

  el('siv-legend').innerHTML = Object.entries(REGION).map(([r, c]) => `<span class="lr"><span class="lr-dot" style="background:${c}"></span>${r}</span>`).join('');

  function beeswarm() {
    const data = atYear(state.ds, periodsOf(state.ds).at(-1));
    const vals = data.map((o) => o.value), min = Math.min(...vals), max = Math.max(...vals);
    const sx = (v) => M.l + (v - min) / ((max - min) || 1) * PW;
    const cy = M.t + PH / 2;
    // simple beeswarm: sort by x, push apart vertically within a band
    const pts = data.map((o) => ({ x: sx(o.value), y: cy, o })).sort((a, b) => a.x - b.x);
    const R = 5;
    for (let i = 0; i < pts.length; i++) {
      let y = cy, dir = 1, step = 0;
      while (pts.some((p, j) => j < i && Math.abs(p.x - pts[i].x) < R * 2 && Math.abs(p.y - y) < R * 2)) { step++; y = cy + dir * step * R * 1.4; dir *= -1; }
      pts[i].y = Math.max(M.t + R, Math.min(M.t + PH - R, y));
    }
    let g = '';
    for (let i = 0; i <= 4; i++) { const v = min + (max - min) * i / 4, x = sx(v); g += `<line x1="${x}" y1="${M.t}" x2="${x}" y2="${M.t + PH}" class="bub-grid"/><text x="${x}" y="${H - 14}" class="bub-axt" text-anchor="middle">${fmt(v)}</text>`; }
    g += pts.map((p) => `<circle cx="${p.x.toFixed(1)}" cy="${p.y.toFixed(1)}" r="${R}" fill="${REGION[p.o.group] || REGION.Other}" fill-opacity="0.8" stroke="#0e0f11" stroke-width="0.6" data-i="${p.o.iso}"><title>${p.o.entity}: ${fmt(p.o.value)}</title></circle>`).join('');
    svg.innerHTML = g; svg._pts = pts.map((p) => ({ ...p.o, _x: p.x, _y: p.y }));
    el('siv-note').textContent = `${data.length} countries · ${periodsOf(state.ds).at(-1)} · each dot is a country, position = ${titleOf(state.slug)}.`;
  }

  function slope() {
    const ps = periodsOf(state.ds); const a = ps[0], b = ps.at(-1);
    if (a === b) { svg.innerHTML = `<text x="${W / 2}" y="${H / 2}" class="bub-axlbl" text-anchor="middle">Single period only</text>`; el('siv-note').textContent = ''; return; }
    const A = new Map(atYear(state.ds, a).map((o) => [o.iso, o])), B = new Map(atYear(state.ds, b).map((o) => [o.iso, o]));
    const rows = [...A.keys()].filter((k) => B.has(k)).map((k) => ({ iso: k, name: A.get(k).entity, va: A.get(k).value, vb: B.get(k).value, group: A.get(k).group }));
    const all = rows.flatMap((r) => [r.va, r.vb]); const min = Math.min(...all), max = Math.max(...all);
    const sy = (v) => M.t + PH - (v - min) / ((max - min) || 1) * PH;
    const xL = M.l + 60, xR = M.l + PW - 60;
    let g = `<text x="${xL}" y="${M.t - 4}" class="bub-axt" text-anchor="middle">${a}</text><text x="${xR}" y="${M.t - 4}" class="bub-axt" text-anchor="middle">${b}</text>`;
    g += rows.map((r) => { const up = r.vb >= r.va; const col = up ? '#34d399' : '#f87171';
      return `<line x1="${xL}" y1="${sy(r.va).toFixed(1)}" x2="${xR}" y2="${sy(r.vb).toFixed(1)}" stroke="${col}" stroke-width="1.2" stroke-opacity="0.5" data-i="${r.iso}"><title>${r.name}: ${fmt(r.va)} → ${fmt(r.vb)}</title></line>`; }).join('');
    // label the biggest movers
    const movers = [...rows].sort((x, y) => Math.abs(y.vb - y.va) - Math.abs(x.vb - x.va)).slice(0, 6);
    g += movers.map((r) => `<text x="${xR + 6}" y="${(sy(r.vb) + 3).toFixed(1)}" class="bub-axt">${r.name}</text>`).join('');
    svg.innerHTML = g; svg._pts = null;
    el('siv-note').textContent = `${rows.length} countries · ${a} → ${b}. Green lines rose, red fell. ${titleOf(state.slug)}.`;
  }

  function raceFrame(p) {
    const data = atYear(state.ds, p).sort((x, y) => y.value - x.value).slice(0, 12);
    const max = Math.max(1, ...data.map((o) => Math.abs(o.value)));
    const rowH = PH / 12;
    let g = `<text x="${M.l + PW - 6}" y="${M.t + 40}" class="bub-watermark" text-anchor="end">${p}</text>`;
    g += data.map((o, i) => { const y = M.t + i * rowH, w = Math.abs(o.value) / max * (PW - 150);
      return `<g><rect x="${M.l + 150}" y="${y + 4}" width="${w.toFixed(1)}" height="${rowH - 8}" rx="3" fill="${REGION[o.group] || REGION.Other}" fill-opacity="0.85"/><text x="${M.l + 146}" y="${y + rowH / 2 + 4}" class="bub-axt" text-anchor="end">${o.entity}</text><text x="${M.l + 156 + w}" y="${y + rowH / 2 + 4}" class="bub-axt">${fmt(o.value)}</text></g>`; }).join('');
    svg.innerHTML = g; svg._pts = null;
    el('siv-note').textContent = `Top 12 · ${p} · ${titleOf(state.slug)}. Press play to animate the ranking over time.`;
  }

  function stopRace() { state.playing = false; el('siv-play').textContent = '▶ Play'; clearInterval(state.timer); }
  function playRace() {
    if (state.playing) { stopRace(); return; }
    const ps = periodsOf(state.ds); state.playing = true; el('siv-play').textContent = '❚❚ Pause';
    const step = Math.max(1, Math.ceil(ps.length / 50)), iv = ps.length > 50 ? 220 : 1100;
    state.timer = setInterval(() => { let i = ps.indexOf(state.raceYear) + step; if (i >= ps.length) i = 0; state.raceYear = ps[i]; raceFrame(state.raceYear); }, iv);
  }

  function render() {
    stopRace();
    el('siv-play').hidden = state.type !== 'race';
    if (state.type === 'beeswarm') beeswarm();
    else if (state.type === 'slope') slope();
    else { state.raceYear = periodsOf(state.ds).at(-1); raceFrame(state.raceYear); }
  }

  async function rebuild() { state.ds = await load(state.slug); render(); }

  el('siv-ind').innerHTML = cfg.indicators.map((d) => `<option value="${d.slug}">${d.title}</option>`).join('');
  el('siv-ind').value = state.slug;
  Array.prototype.forEach.call(el('siv-type').children, (x) => x.classList.toggle('active', x.dataset.t === state.type));
  el('siv-ind').addEventListener('change', (e) => { state.slug = e.target.value; rebuild(); syncUrl(); });
  el('siv-type').addEventListener('click', (e) => { const b = e.target.closest('button'); if (!b) return; state.type = b.dataset.t; Array.prototype.forEach.call(el('siv-type').children, (x) => x.classList.toggle('active', x === b)); render(); syncUrl(); });
  el('siv-play').addEventListener('click', playRace);
  svg.addEventListener('mousemove', (e) => {
    const t = e.target;
    if (t.tagName === 'circle' && svg._pts) { const d = svg._pts.find((p) => p.iso === t.getAttribute('data-i'));
      if (d) { tip.hidden = false; tip.innerHTML = `<b>${d.entity}</b><br>${fmt(d.value)}`; const r = svg.getBoundingClientRect(); tip.style.left = (e.clientX - r.left + 12) + 'px'; tip.style.top = (e.clientY - r.top + 12) + 'px'; } }
    else tip.hidden = true;
  });
  svg.addEventListener('mouseleave', () => { tip.hidden = true; });
  rebuild();
</script>
