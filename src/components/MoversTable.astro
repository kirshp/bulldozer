---
import type { Observation, ChangeMode } from '@lib/analytics';
import { topGrowth, topDecline } from '@lib/analytics';
import { formatChange, pctClass, formatNum } from '@lib/format';
import { flagFor } from '@lib/flags';

interface Props { data: Observation[]; n?: number; unit?: string; mode?: ChangeMode }
const { data, n = 5, unit = '', mode = 'pct' } = Astro.props;
const up = topGrowth(data, n, mode);
const down = topDecline(data, n, mode);
const isoOf = new Map(data.filter((o) => o.iso).map((o) => [o.entity, o.iso!]));
const label = (e: string) => { const f = flagFor(isoOf.get(e)); return f ? f + ' ' + e : e; };
---
<div class="grid cols-2">
  <div>
    <h3>Top risers</h3>
    <table class="data">
      <thead><tr><th>Entity</th><th class="num">Now</th><th class="num">Change</th></tr></thead>
      <tbody>
        {up.map((r) => (
          <tr>
            <td>{label(r.entity)}</td>
            <td class="num">{formatNum(r.curr)}{unit}</td>
            <td class={`num ${pctClass(r.pct)}`}>{formatChange(r.pct, mode)}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  <div>
    <h3>Top fallers</h3>
    <table class="data">
      <thead><tr><th>Entity</th><th class="num">Now</th><th class="num">Change</th></tr></thead>
      <tbody>
        {down.map((r) => (
          <tr>
            <td>{label(r.entity)}</td>
            <td class="num">{formatNum(r.curr)}{unit}</td>
            <td class={`num ${pctClass(r.pct)}`}>{formatChange(r.pct, mode)}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>
